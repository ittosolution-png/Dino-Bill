<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('partials/head') %>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <style>
        :root { --primary: #8B5CF6; --primary-soft: rgba(139, 92, 246, 0.1); }
        body { background: var(--bg-color); color: var(--text); margin: 0; padding-bottom: 90px; transition: background 0.3s, color 0.3s; display: flex; flex-direction: column; min-height: 100vh; }
        .portal-header { background: var(--sidebar-bg); padding: 15px 20px; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; position: sticky; top: 0; z-index: 1000; backdrop-filter: blur(10px); width: 100%; }
        .portal-title { font-size: 18px; font-weight: 700; margin: 0; }
        .portal-subtitle { font-size: 12px; color: var(--muted); margin-top: 2px; }
        .content { padding: 20px; width: 100%; flex: 1; }
        .section-title { font-size: 14px; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: 1px; margin: 24px 0 12px; }
        .ticket-card { background: var(--card-bg); border: 1px solid var(--border); border-radius: 16px; padding: 18px; margin-bottom: 16px; position: relative; overflow: hidden; }
        .ticket-card.priority-high { border-left: 4px solid #EF4444; }
        .ticket-card.priority-normal { border-left: 4px solid #3B82F6; }
        .ticket-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 12px; }
        .ticket-title { font-size: 18px; font-weight: 700; margin: 0; }
        .ticket-customer { font-size: 14px; font-weight: 500; color: var(--text); margin: 6px 0; display: flex; align-items: center; gap: 6px; }
        .ticket-address { font-size: 13px; color: var(--muted); line-height: 1.4; margin-bottom: 16px; }
        .ticket-actions { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 15px; }
        .btn-action { display: flex; align-items: center; justify-content: center; gap: 8px; padding: 10px; border-radius: 10px; font-size: 13px; font-weight: 600; border: none; cursor: pointer; text-decoration: none; }
        .btn-map { background: rgba(59, 130, 246, 0.1); color: #3B82F6; }
        .btn-wa { background: rgba(16, 185, 129, 0.1); color: #10B981; }
        .btn-done { background: #8B5CF6; color: white; grid-column: 1 / -1; margin-top: 5px; }
        .empty-state { text-align: center; padding: 60px 20px; color: var(--muted); }
        .bottom-nav { position: fixed; bottom: 0; left: 0; right: 0; background: var(--topbar-bg); backdrop-filter: blur(10px); border-top: 1px solid var(--border); display: flex; justify-content: space-around; padding: 12px 10px; z-index: 1001; }
        .nav-item { display: flex; flex-direction: column; align-items: center; gap: 4px; color: var(--muted); text-decoration: none; font-size: 11px; font-weight: 500; cursor: pointer; }
        .nav-item.active { color: #8B5CF6; }
        .badge { padding: 4px 8px; border-radius: 6px; font-size: 10px; font-weight: 700; text-transform: uppercase; }
        .badge-high { background: rgba(239, 68, 68, 0.2); color: #F87171; }
        .badge-normal { background: rgba(59, 130, 246, 0.2); color: #60A5FA; }

        /* Map Styles */
        #map-container { position: fixed; top: 75px; left: 0; right: 0; bottom: 85px; z-index: 900; display: none; }
        #map { width: 100%; height: 100%; }
        .leaflet-popup-content-wrapper { background: var(--card-bg); color: var(--text); border: 1px solid var(--border); border-radius: 12px; }
        .leaflet-popup-tip { background: var(--card-bg); }
        .popup-title { font-weight: 700; font-size: 14px; margin-bottom: 4px; display: block; }
        .popup-address { font-size: 11px; color: var(--muted); }
    </style>
</head>
<body>
    <div class="portal-header">
        <div>
            <h1 class="portal-title"><%= t.technician_portal %></h1>
            <p class="portal-subtitle">Halo, <%= user.username %>!</p>
        </div>
        <div style="display:flex; gap:10px; align-items:center;">
            <button id="themeToggle" style="background:var(--card-bg); border:1px solid var(--border); color:var(--text); width:38px; height:38px; border-radius:10px; cursor:pointer; display:flex; align-items:center; justify-content:center;">
                <i class="fas fa-moon"></i>
            </button>
        </div>
    </div>

    <div class="content" id="tasks-content">
        <!-- Search Section -->
        <div style="margin-bottom:24px;">
            <form action="/technician" method="GET" style="display:flex; gap:10px;">
                <div style="flex:1; position:relative;">
                    <svg style="position:absolute; left:14px; top:50%; transform:translateY(-50%); color:var(--muted);" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                    <input type="text" name="search" class="form-control" placeholder="<%= t.search_customer_placeholder %>" value="<%= search %>" style="padding-left:44px; height:52px; border-radius:14px; font-size:15px;">
                </div>
                <button type="submit" class="btn btn-primary" style="height:52px; padding:0 24px; border-radius:14px; font-weight:700;"><%= t.search_btn %></button>
            </form>
        </div>

        <% if (search) { %>
            <div class="section-title">Hasil Pencarian</div>
            <% if (searchResults.length > 0) { %>
                <% searchResults.forEach(c => { %>
                    <div class="ticket-card" style="border-left:4px solid var(--primary);">
                        <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:12px;">
                            <div>
                                <h3 style="font-size:16px; font-weight:600; margin:0;"><%= c.name %></h3>
                                <div style="font-size:12px; color:var(--muted); margin-top:4px;">PPPoE: <span style="color:var(--primary); font-weight:600;"><%= c.pppoe_username %></span></div>
                            </div>
                            <span class="badge" style="background:<%= c.status==='active'?'rgba(16,185,129,.15)':'rgba(239,68,68,.15)'%>; color:<%= c.status==='active'?'#10B981':'#EF4444'%>">
                                <%= c.status.toUpperCase() %>
                            </span>
                        </div>

                        <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:15px; background:var(--input-bg); padding:12px; border-radius:12px; border:1px solid var(--border);">
                            <div>
                                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:4px;">
                                    <span style="font-size:11px; color:var(--muted);">RX Power</span>
                                    <button class="btn-refresh-onu" onclick="refreshOnu('<%= c.id %>', '<%= c.olt_id %>', '<%= c.onu_index %>')" style="background:none; border:none; padding:0; color:var(--primary); cursor:pointer;">
                                        <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                                    </button>
                                </div>
                                <div id="rx-val-<%= c.id %>" style="font-size:14px; font-weight:700; color:<%= parseFloat(c.rx_power) < -27 ? '#EF4444' : '#10B981' %>">
                                    <%= c.rx_power || '--' %> dBm
                                </div>
                            </div>
                            <div>
                                <div style="font-size:11px; color:var(--muted); margin-bottom:4px;">Status ONU</div>
                                <div style="font-size:13px; font-weight:600;">
                                    <%= c.onu_status || 'Unknown' %>
                                </div>
                            </div>
                        </div>

                        <div class="ticket-actions" style="grid-template-columns: 1fr 1fr; gap: 10px;">
                            <a href="https://wa.me/<%= (c.phone||'').replace(/[^0-9]/g,'') %>" target="_blank" class="btn-action btn-wa" style="font-size:12px;">
                                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                                WhatsApp
                            </a>
                            <button class="btn-action btn-map" onclick="fetchWifi('<%= c.id %>', '<%= c.pppoe_username %>')" style="font-size:12px;">
                                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M8.111 16.404a5.5 5.5 0 117.778 0M12 20h.01m-7.08-7.071a9.914 9.914 0 0114.142 0M1.05 9.464a18.917 18.917 0 0121.9 0"/></svg>
                                WiFi
                            </button>
                        </div>
                        <div id="wifi-info-<%= c.id %>" style="display:none; margin-top:12px; background:rgba(139,92,246,0.1); padding:10px; border-radius:10px; border:1px solid rgba(139,92,246,0.2);">
                            <div style="font-size:12px; font-weight:600; margin-bottom:2px;">SSID: <span class="ssid-val" style="color:var(--primary)">-</span></div>
                            <div style="font-size:12px; font-weight:600;">Pass: <span class="pass-val" style="color:var(--primary)">-</span></div>
                        </div>
                    </div>
                <% }); %>
            <% } %>
            <hr style="border:0; border-top:1px solid var(--border); margin:20px 0;">
        <% } %>

        <div class="section-title"><%= t.active_tasks %> (<%= tickets.length %>)</div>

        <% if (tickets.length > 0) { %>
            <% tickets.forEach(t => { %>
                <div class="ticket-card priority-<%= t.priority %>" id="ticket-<%= t.id %>">
                    <div class="ticket-header">
                        <h2 class="ticket-title"><%= t.title %></h2>
                        <span class="badge badge-<%= t.priority %>"><%= t.priority %></span>
                    </div>
                    
                    <div class="ticket-customer">
                        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                        <%= t.customer_name %>
                    </div>
                    
                    <div class="ticket-address">
                        <%= t.customer_address || 'No address' %>
                    </div>

                    <div class="ticket-actions">
                        <% if (t.lat && t.lng) { %>
                            <a href="https://www.google.com/maps?q=<%= t.lat %>,<%= t.lng %>" target="_blank" class="btn-action btn-map">
                                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                                Navigasi
                            </a>
                        <% } %>

                        <a href="https://wa.me/<%= (t.customer_phone||'').replace(/[^0-9]/g,'') %>" target="_blank" class="btn-action btn-wa">
                            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                            WA
                        </a>

                        <button class="btn-action btn-done" onclick="closeTicket(<%= t.id %>)">
                            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg>
                            <%= t.done %>
                        </button>
                    </div>
                </div>
            <% }); %>
        <% } else { %>
            <div class="empty-state">
                <p>Tidak ada tugas terbuka.</p>
            </div>
        <% } %>
    </div>

    <!-- Map Container -->
    <div id="map-container">
        <div id="map"></div>
    </div>

    <div class="bottom-nav">
        <div onclick="switchTab('tasks')" id="nav-tasks" class="nav-item active">
            <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
            <span><%= t.tasks %></span>
        </div>
        <div onclick="switchTab('map')" id="nav-map" class="nav-item">
            <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <span><%= t.map %></span>
        </div>
        <a href="/logout" class="nav-item">
            <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
            <span><%= t.logout %></span>
        </a>
    </div>

    <div id="toast" style="position:fixed;bottom:90px;left:20px;right:20px;background:var(--toast-bg);color:var(--text);border:1px solid var(--border);border-radius:12px;padding:14px 20px;z-index:9999;display:none;font-size:14px;box-shadow:0 10px 25px rgba(0,0,0,0.2);"></div>

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        const customerMarkers = <%- JSON.stringify(customerMarkers) %>;
        const tickets = <%- JSON.stringify(tickets) %>;
        const mapObjects = <%- JSON.stringify(mapObjects || []) %>;
        const mapCables = <%- JSON.stringify(mapCables || []) %>;
        let map = null;

        function switchTab(tab) {
            document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
            document.getElementById('tasks-content').style.display = tab === 'tasks' ? 'block' : 'none';
            document.getElementById('map-container').style.display = tab === 'map' ? 'block' : 'none';
            document.getElementById('nav-' + tab).classList.add('active');

            if (tab === 'map') {
                if (!map) initMap();
                setTimeout(() => map.invalidateSize(), 100);
            }
        }

        function initMap() {
            map = L.map('map').setView([-6.200000, 106.816666], 13);
            L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
                attribution: '&copy; OpenStreetMap contributors'
            }).addTo(map);

            const markers = L.featureGroup();
            const infraGroup = L.layerGroup().addTo(map);

            // Icons
            const serverIcon = L.divIcon({
                html: '<div style="color:#8B5CF6; font-size:20px"><i class="fas fa-server"></i></div>',
                className: 'custom-div-icon', iconSize: [24, 24], iconAnchor: [12, 12]
            });
            const odpIcon = L.divIcon({
                html: '<div style="color:#F59E0B; font-size:18px"><i class="fas fa-box-open"></i></div>',
                className: 'custom-div-icon', iconSize: [20, 20], iconAnchor: [10, 10]
            });

            // Render Infrastructure
            mapObjects.forEach(obj => {
                const icon = obj.type === 'server' ? serverIcon : odpIcon;
                L.marker([obj.lat, obj.lng], { icon }).addTo(infraGroup)
                    .bindPopup(`<b>${obj.name}</b><br>Tipe: ${obj.type.toUpperCase()}`);
            });

            mapCables.forEach(cb => {
                L.polyline(cb.path, { 
                    color: cb.color || '#3b82f6', 
                    weight: 3, 
                    opacity: 0.6,
                    className: 'flow-line'
                }).addTo(infraGroup);
            });

            // Add Customer Markers
            customerMarkers.forEach(c => {
                const marker = L.circleMarker([c.lat, c.lng], {
                    radius: 6,
                    fillColor: c.status === 'active' ? '#10B981' : '#EF4444',
                    color: "#fff", weight: 1, opacity: 1, fillOpacity: 0.8
                }).addTo(markers);

                marker.bindPopup(`
                    <span class="popup-title">${c.name}</span>
                    <span class="popup-address">${c.address || '-'}</span><br>
                    <div style="margin-top:5px; font-size:10px; font-weight:700; color:${c.status === 'active' ? '#10B981' : '#EF4444'}">
                        ${c.status.toUpperCase()}
                    </div>
                `);
            });

            // Highlight Ticket Markers with Pulsing effect (simple circle)
            tickets.forEach(t => {
                if (t.lat && t.lng) {
                    const marker = L.circleMarker([t.lat, t.lng], {
                        radius: 10,
                        fillColor: t.priority === 'high' ? '#EF4444' : '#3B82F6',
                        color: "#fff", weight: 2, opacity: 1, fillOpacity: 0.6
                    }).addTo(markers);

                    marker.bindPopup(`
                        <span class="popup-title" style="color:#EF4444">⚠️ TUGAS: ${t.title}</span>
                        <span class="popup-address">${t.customer_name}</span>
                    `);
                }
            });

            markers.addTo(map);
            if (markers.getLayers().length > 0) {
                map.fitBounds(markers.getBounds().pad(0.1));
            }
        }

        async function closeTicket(id) {
            if (!confirm('Tandai tugas ini sebagai selesai?')) return;
            try {
                const res = await fetch(`/tickets/api/${id}/close`, { method: 'POST' });
                const d = await res.json();
                showToast(d.message, d.success ? 'success' : 'error');
                if (d.success) setTimeout(() => location.reload(), 1500);
            } catch(e) {
                showToast('Gagal: ' + e.message, 'error');
            }
        }

        async function fetchWifi(id, pppoe) {
            const container = document.getElementById('wifi-info-' + id);
            container.style.display = 'block';
            container.querySelector('.ssid-val').textContent = 'Loading...';
            container.querySelector('.pass-val').textContent = 'Loading...';
            try {
                const res = await fetch(`/technician/api/wifi-info?pppoe=${encodeURIComponent(pppoe)}`);
                const d = await res.json();
                if (d.success) {
                    container.querySelector('.ssid-val').textContent = d.ssid;
                    container.querySelector('.pass-val').textContent = d.password;
                } else {
                    container.querySelector('.ssid-val').textContent = 'Not Found';
                    container.querySelector('.pass-val').textContent = '-';
                }
            } catch (e) { showToast('Error: ' + e.message, 'error'); }
        }

        async function refreshOnu(id, oltId, index) {
            const el = document.getElementById('rx-val-' + id);
            el.textContent = '⏳ ...';
            try {
                const res = await fetch(`/technician/api/onu-info?olt_id=${oltId}&index=${index}`);
                const d = await res.json();
                if (d.success) {
                    el.textContent = d.rx_power + ' dBm';
                    const rx = parseFloat(d.rx_power);
                    el.style.color = rx < -27 ? '#EF4444' : '#10B981';
                } else { showToast(d.message, 'error'); }
            } catch (e) { showToast('Failed: ' + e.message, 'error'); }
        }

        function showToast(msg,type){const t=document.getElementById('toast');t.textContent=msg;t.style.color=type==='success'?'#10B981':'#EF4444';t.style.display='block';setTimeout(()=>t.style.display='none',3500);}

        // Theme Logic
        const themeToggle = document.getElementById('themeToggle');
        themeToggle.addEventListener('click', () => {
            const isLight = document.documentElement.classList.toggle('light-theme');
            localStorage.setItem('theme', isLight ? 'light' : 'dark');
            themeToggle.querySelector('i').className = isLight ? 'fas fa-sun' : 'fas fa-moon';
        });
        if (localStorage.getItem('theme') === 'light') {
            document.documentElement.classList.add('light-theme');
            themeToggle.querySelector('i').className = 'fas fa-sun';
        }
    </script>
</body>
</html>
