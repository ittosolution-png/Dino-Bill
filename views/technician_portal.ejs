<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('partials/head') %>
    <style>
        :root { --primary: #8B5CF6; --primary-soft: rgba(139, 92, 246, 0.1); }
        body { background: var(--bg-color); color: var(--text); margin: 0; padding-bottom: 80px; transition: background 0.3s, color 0.3s; }
        .portal-header { background: var(--sidebar-bg); padding: 24px 20px; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; }
        .portal-title { font-size: 20px; font-weight: 700; margin: 0; }
        .portal-subtitle { font-size: 13px; color: var(--muted); margin-top: 4px; }
        .content { padding: 20px; }
        .section-title { font-size: 14px; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: 1px; margin: 24px 0 12px; }
        .ticket-card { background: var(--card-bg); border: 1px solid var(--border); border-radius: 16px; padding: 18px; margin-bottom: 16px; position: relative; overflow: hidden; }
        .ticket-card.priority-high { border-left: 4px solid #EF4444; }
        .ticket-card.priority-normal { border-left: 4px solid #3B82F6; }
        .ticket-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 12px; }
        .ticket-title { font-size: 16px; font-weight: 600; margin: 0; }
        .ticket-customer { font-size: 14px; font-weight: 500; color: var(--text); margin: 6px 0; display: flex; align-items: center; gap: 6px; }
        .ticket-address { font-size: 13px; color: var(--muted); line-height: 1.4; margin-bottom: 16px; }
        .ticket-actions { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 15px; }
        .btn-action { display: flex; align-items: center; justify-content: center; gap: 8px; padding: 10px; border-radius: 10px; font-size: 13px; font-weight: 600; border: none; cursor: pointer; text-decoration: none; }
        .btn-map { background: rgba(59, 130, 246, 0.1); color: #3B82F6; }
        .btn-wa { background: rgba(16, 185, 129, 0.1); color: #10B981; }
        .btn-done { background: #8B5CF6; color: white; grid-column: 1 / -1; margin-top: 5px; }
        .empty-state { text-align: center; padding: 60px 20px; color: var(--muted); }
        .bottom-nav { position: fixed; bottom: 0; left: 0; right: 0; background: var(--topbar-bg); backdrop-filter: blur(10px); border-top: 1px solid var(--border); display: flex; justify-content: space-around; padding: 12px 10px; z-index: 1000; }
        .nav-item { display: flex; flex-direction: column; align-items: center; gap: 4px; color: var(--muted); text-decoration: none; font-size: 11px; font-weight: 500; }
        .nav-item.active { color: #8B5CF6; }
        .badge { padding: 4px 8px; border-radius: 6px; font-size: 10px; font-weight: 700; text-transform: uppercase; }
        .badge-high { background: rgba(239, 68, 68, 0.2); color: #F87171; }
        .badge-normal { background: rgba(59, 130, 246, 0.2); color: #60A5FA; }
    </style>
</head>
<body>
    <div class="portal-header">
        <div>
            <h1 class="portal-title">Portal Teknisi</h1>
            <p class="portal-subtitle">Halo, <%= user.username %>! Selamat bertugas.</p>
        </div>
        <div style="display:flex; gap:10px; align-items:center;">
            <button id="themeToggle" style="background:var(--card-bg); border:1px solid var(--border); color:var(--text); width:38px; height:38px; border-radius:10px; cursor:pointer; display:flex; align-items:center; justify-content:center;">
                <i class="fas fa-moon"></i>
            </button>
        </div>
    </div>

    <div class="content">
        <!-- Search Section -->
        <div style="margin-bottom:24px;">
            <form action="/technician" method="GET" style="display:flex; gap:10px;">
                <div style="flex:1; position:relative;">
                    <svg style="position:absolute; left:12px; top:50%; transform:translateY(-50%); color:var(--muted);" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                    <input type="text" name="search" class="form-control" placeholder="Cari WA / PPPoE / Nama..." value="<%= search %>" style="padding-left:38px; height:46px; border-radius:12px;">
                </div>
                <button type="submit" class="btn btn-primary" style="height:46px; padding:0 20px; border-radius:12px;">Cari</button>
            </form>
        </div>

        <% if (search) { %>
            <div class="section-title">Hasil Pencarian Pelanggan</div>
            <% if (searchResults.length > 0) { %>
                <% searchResults.forEach(c => { %>
                    <div class="ticket-card" style="border-left:4px solid var(--primary);">
                        <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:12px;">
                            <div>
                                <h3 style="font-size:16px; font-weight:600; margin:0;"><%= c.name %></h3>
                                <div style="font-size:12px; color:var(--muted); margin-top:4px;">PPPoE: <span style="color:var(--primary); font-weight:600;"><%= c.pppoe_username %></span></div>
                            </div>
                            <span class="badge" style="background:<%= c.status==='active'?'rgba(16,185,129,.15)':'rgba(239,68,68,.15)'%>; color:<%= c.status==='active'?'#10B981':'#EF4444'%>">
                                <%= c.status.toUpperCase() %>
                            </span>
                        </div>

                        <div style="grid-column: 1 / -1; display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:15px; background:var(--input-bg); padding:12px; border-radius:12px; border:1px solid var(--border);">
                            <div>
                                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:4px;">
                                    <span style="font-size:11px; color:var(--muted);">RX Power (Redaman)</span>
                                    <button class="btn-refresh-onu" onclick="refreshOnu('<%= c.id %>', '<%= c.olt_id %>', '<%= c.onu_index %>')" style="background:none; border:none; padding:0; color:var(--primary); cursor:pointer;">
                                        <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                                    </button>
                                </div>
                                <div id="rx-val-<%= c.id %>" style="font-size:14px; font-weight:700; color:<%= parseFloat(c.rx_power) < -27 ? '#EF4444' : '#10B981' %>">
                                    <%= c.rx_power || '--' %> dBm
                                </div>
                            </div>
                            <div>
                                <div style="font-size:11px; color:var(--muted); margin-bottom:4px;">Status ONU</div>
                                <div style="font-size:13px; font-weight:600;">
                                    <%= c.onu_status || 'Unknown' %>
                                </div>
                            </div>
                        </div>

                        <div id="wifi-info-<%= c.id %>" style="display:none; margin-bottom:15px; background:rgba(139,92,246,0.1); padding:12px; border-radius:12px; border:1px solid rgba(139,92,246,0.2);">
                            <div style="font-size:11px; color:var(--muted); margin-bottom:4px;">Informasi WiFi (GenieACS)</div>
                            <div style="font-size:13px; font-weight:600; margin-bottom:2px;">SSID: <span class="ssid-val" style="color:var(--primary)">-</span></div>
                            <div style="font-size:13px; font-weight:600;">Pass: <span class="pass-val" style="color:var(--primary)">-</span></div>
                        </div>

                        <div class="ticket-actions">
                            <a href="https://wa.me/<%= (c.phone||'').replace(/[^0-9]/g,'') %>" target="_blank" class="btn-action btn-wa">
                                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                                WhatsApp
                            </a>
                            <button class="btn-action btn-map" onclick="fetchWifi('<%= c.id %>', '<%= c.pppoe_username %>')">
                                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M8.111 16.404a5.5 5.5 0 117.778 0M12 20h.01m-7.08-7.071a9.914 9.914 0 0114.142 0M1.05 9.464a18.917 18.917 0 0121.9 0"/></svg>
                                Cek WiFi
                            </button>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <div class="empty-state" style="padding:20px;">Pelanggan tidak ditemukan.</div>
            <% } %>
            <hr style="border:0; border-top:1px solid var(--border); margin:20px 0;">
        <% } %>
        <div class="section-title">Tugas Aktif (<%= tickets.length %>)</div>

        <% if (tickets.length > 0) { %>
            <% tickets.forEach(t => { %>
                <div class="ticket-card priority-<%= t.priority %>" id="ticket-<%= t.id %>">
                    <div class="ticket-header">
                        <h2 class="ticket-title"><%= t.title %></h2>
                        <span class="badge badge-<%= t.priority %>"><%= t.priority === 'high' ? 'High' : 'Normal' %></span>
                    </div>
                    
                    <div class="ticket-customer">
                        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                        <%= t.customer_name %>
                    </div>
                    
                    <div class="ticket-address">
                        <%= t.customer_address || 'Alamat tidak tersedia' %>
                    </div>

                    <% if (t.description) { %>
                        <div style="background:var(--input-bg); padding:10px; border-radius:8px; font-size:12px; color:var(--text); margin-bottom:15px; font-style:italic;">
                            "<%= t.description %>"
                        </div>
                    <% } %>

                    <div class="ticket-actions">
                        <% if (t.lat && t.lng) { %>
                            <a href="https://www.google.com/maps?q=<%= t.lat %>,<%= t.lng %>" target="_blank" class="btn-action btn-map">
                                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                                Peta
                            </a>
                        <% } else { %>
                            <div class="btn-action btn-map" style="opacity:0.5; cursor:not-allowed">
                                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                                Peta
                            </div>
                        <% } %>

                        <a href="https://wa.me/<%= (t.customer_phone||'').replace(/[^0-9]/g,'') %>" target="_blank" class="btn-action btn-wa">
                            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                            Hubungi
                        </a>

                        <button class="btn-action btn-done" onclick="closeTicket(<%= t.id %>)">
                            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg>
                            Selesaikan Tugas
                        </button>
                    </div>
                </div>
            <% }); %>
        <% } else { %>
            <div class="empty-state">
                <svg width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" style="margin-bottom:12px; opacity:0.2;"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <p>Tidak ada tugas terbuka.<br>Semua pekerjaan sudah selesai!</p>
            </div>
        <% } %>
    </div>

    <div class="bottom-nav">
        <a href="/technician" class="nav-item active">
            <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
            <span>Tugas</span>
        </a>
        <a href="/logout" class="nav-item">
            <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
            <span>Keluar</span>
        </a>
    </div>

    <div id="toast" style="position:fixed;bottom:80px;left:20px;right:20px;background:#1E293B;border:1px solid rgba(255,255,255,0.1);border-radius:12px;padding:14px 20px;z-index:9999;display:none;font-size:14px;box-shadow:0 10px 25px rgba(0,0,0,0.5);"></div>

    <script>
        async function closeTicket(id) {
            if (!confirm('Tandai tugas ini sebagai selesai?')) return;
            try {
                const res = await fetch(`/tickets/api/${id}/close`, { method: 'POST' });
                const d = await res.json();
                showToast(d.message, d.success ? 'success' : 'error');
                if (d.success) {
                    document.getElementById('ticket-' + id).style.opacity = '0.5';
                    document.getElementById('ticket-' + id).style.pointerEvents = 'none';
                    setTimeout(() => location.reload(), 1500);
                }
            } catch(e) {
                showToast('Gagal: ' + e.message, 'error');
            }
        }

        async function fetchWifi(id, pppoe) {
            const container = document.getElementById('wifi-info-' + id);
            container.style.display = 'block';
            container.querySelector('.ssid-val').textContent = '⏳ Loading...';
            container.querySelector('.pass-val').textContent = '⏳ Loading...';

            try {
                const res = await fetch(`/technician/api/wifi-info?pppoe=${encodeURIComponent(pppoe)}`);
                const d = await res.json();
                if (d.success) {
                    container.querySelector('.ssid-val').textContent = d.ssid;
                    container.querySelector('.pass-val').textContent = d.password;
                } else {
                    container.querySelector('.ssid-val').textContent = 'Not Found';
                    container.querySelector('.pass-val').textContent = '-';
                    showToast(d.message, 'error');
                }
            } catch (e) {
                showToast('Error: ' + e.message, 'error');
            }
        }

        async function refreshOnu(id, oltId, index) {
            const el = document.getElementById('rx-val-' + id);
            const originalColor = el.style.color;
            el.textContent = '⏳ ...';
            el.style.color = 'var(--muted)';

            try {
                const res = await fetch(`/technician/api/onu-info?olt_id=${oltId}&index=${index}`);
                const d = await res.json();
                if (d.success) {
                    el.textContent = d.rx_power + ' dBm';
                    const rx = parseFloat(d.rx_power);
                    el.style.color = rx < -27 ? '#EF4444' : '#10B981';
                    showToast('Data RX Power diperbarui secara real-time', 'success');
                } else {
                    el.textContent = 'Error';
                    el.style.color = '#EF4444';
                    showToast(d.message, 'error');
                }
            } catch (e) {
                el.textContent = 'Failed';
                showToast('Gagal refresh: ' + e.message, 'error');
            }
        }
        function showToast(msg,type){const t=document.getElementById('toast');t.textContent=msg;t.style.color=type==='success'?'#10B981':'#EF4444';t.style.display='block';setTimeout(()=>t.style.display='none',3500);}

        // Theme Logic
        const themeToggle = document.getElementById('themeToggle');
        const themeIcon = themeToggle.querySelector('i');
        function updateThemeUI() {
            const isLight = document.documentElement.classList.contains('light-theme');
            themeIcon.className = isLight ? 'fas fa-sun' : 'fas fa-moon';
            themeToggle.style.color = isLight ? '#F59E0B' : 'var(--text)';
        }
        updateThemeUI();
        themeToggle.addEventListener('click', () => {
            const isLight = document.documentElement.classList.toggle('light-theme');
            localStorage.setItem('theme', isLight ? 'light' : 'dark');
            updateThemeUI();
        });
    </script>
</body>
</html>
