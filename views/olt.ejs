<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('partials/head') %>
    <style>
        .stats-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(240px,1fr)); gap:20px; margin-bottom:30px; }
        .stat-card { background:var(--card-bg); border:1px solid var(--border); border-radius:18px; padding:24px; display:flex; align-items:center; gap:20px; cursor:pointer; transition:all 0.3s; position:relative; overflow:hidden; }
        .stat-card:hover { transform:translateY(-5px); border-color:var(--primary); background:var(--sidebar-bg); }
        .stat-card::after { content:''; position:absolute; left:0; top:0; height:100%; width:4px; background:var(--card-color); }
        
        .stat-icon { width:52px; height:52px; border-radius:12px; display:flex; align-items:center; justify-content:center; font-size:24px; background:var(--sub-bg); color:var(--card-color); }
        .stat-info h3 { font-size:28px; font-weight:800; margin:0; line-height:1; }
        .stat-info p { font-size:13px; color:var(--muted); margin:8px 0 0; }

        .olt-box { background:var(--card-bg); border:1px solid var(--border); border-radius:22px; overflow:hidden; }
        .tab-bar { display:flex; background:var(--sub-bg); border-bottom:1px solid var(--border); }
        .tab-bar button { padding:18px 25px; background:none; border:none; color:var(--muted); font-weight:600; cursor:pointer; transition:all 0.3s; border-bottom:3px solid transparent; display:flex; align-items:center; gap:8px; font-size:14px; }
        .tab-bar button.active { color:var(--primary); border-bottom-color:var(--primary); background:rgba(59,130,246,0.05); }
        
        .tab-pane { padding:30px; display:none; animation:fadeIn 0.4s ease; }
        .tab-pane.active { display:block; }
        @keyframes fadeIn { from { opacity:0; transform:translateY(10px); } to { opacity:1; transform:translateY(0); } }

        .table-container { width:100%; overflow-x:auto; }
        table { width:100%; border-collapse:collapse; }
        th { background:var(--sub-bg); color:var(--muted); font-weight:600; font-size:11px; text-transform:uppercase; letter-spacing:1px; padding:15px 20px; text-align:left; }
        td { padding:15px 20px; border-bottom:1px solid var(--border); font-size:13px; color:var(--text); vertical-align:middle; }
        tr:hover td { background:var(--hover-bg); }

        .sig-badge { font-family:monospace; font-weight:700; }
        .sig-good { color:#10B981; }
        .sig-warn { color:#F59E0B; }
        .sig-bad { color:#EF4444; }

        .status-badge { padding:6px 12px; border-radius:20px; font-size:11px; font-weight:700; display:inline-flex; align-items:center; gap:6px; }
        .status-up { background:rgba(16,185,129,0.1); color:#10B981; border:1px solid rgba(16,185,129,0.2); }
        .status-down { background:rgba(239,68,68,0.1); color:#EF4444; border:1px solid rgba(239,68,68,0.2); }

        .btn-action { width:32px; height:32px; border-radius:8px; display:flex; align-items:center; justify-content:center; border:1px solid var(--border); background:var(--sub-bg); color:var(--muted); cursor:pointer; transition:all 0.2s; }
        .btn-action:hover { background:var(--primary); color:white; border-color:var(--primary); transform:scale(1.1); }
        .btn-action.danger:hover { background:var(--danger); border-color:var(--danger); }

        .modal-overlay { position:fixed; inset:0; background:var(--overlay-bg); backdrop-filter:blur(6px); display:none; align-items:center; justify-content:center; z-index:2000; padding:20px; }
        .form-control { background:var(--sub-bg); border:1px solid var(--border); color:var(--text); border-radius:12px; padding:12px 16px; width:100%; transition:all 0.3s; font-size:14px; }
        .form-control:focus { border-color:var(--primary); outline:none; box-shadow:0 0 0 4px rgba(59,130,246,0.1); background:var(--card-bg); }
        .form-group label { display:block; margin-bottom:8px; font-size:13px; font-weight:600; color:var(--muted); }

        .modal-card { background:var(--sidebar-bg); border:1px solid var(--border); border-radius:28px; width:100%; max-width:550px; padding:35px; box-shadow:0 25px 80px rgba(0,0,0,0.5); position:relative; }
        .modal-card h3 { font-weight:800; letter-spacing:-0.5px; }
        
        .toast { position:fixed; top:24px; right:24px; background:var(--toast-bg); color:var(--text); border-radius:12px; padding:18px 25px; z-index:9999; display:none; border-left:5px solid var(--primary); box-shadow:0 15px 40px rgba(0,0,0,0.4); max-width:400px; font-size:14px; animation:slideIn 0.3s ease; }
        @keyframes slideIn { from { transform:translateX(50px); opacity:0; } to { transform:translateX(0); opacity:1; } }
    </style>
</head>
<body>
<%- include('partials/sidebar') %>
<main class="main">
    <%- include('partials/topbar', { title: t.olt_management }) %>
    <div class="content">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:30px;">
            <h1 class="page-title" style="margin:0;"><%= t.olt_monitor_title %></h1>
            <button class="btn btn-primary" onclick="syncOLT()">
                <i class="fas fa-sync-alt"></i> <%= t.sync_olt_data %>
            </button>
        </div>

        <!-- STATS -->
        <div class="stats-grid">
            <div class="stat-card" style="--card-color: var(--primary)" onclick="filterTable('')">
                <div class="stat-icon"><i class="fas fa-microchip"></i></div>
                <div class="stat-info">
                    <h3><%= onus.length %></h3>
                    <p><%= t.total_onu %></p>
                </div>
            </div>
            <div class="stat-card" style="--card-color: #10B981" onclick="filterTable('Online')">
                <div class="stat-icon"><i class="fas fa-wifi"></i></div>
                <div class="stat-info">
                    <h3><%= onus.filter(o => o.status === 'Up').length %></h3>
                    <p><%= t.onu_online %></p>
                </div>
            </div>
            <div class="stat-card" style="--card-color: #EF4444" onclick="filterTable('Offline')">
                <div class="stat-icon"><i class="fas fa-power-off"></i></div>
                <div class="stat-info">
                    <h3><%= onus.filter(o => o.status !== 'Up').length %></h3>
                    <p><%= t.onu_offline %></p>
                </div>
            </div>
            <div class="stat-card" style="--card-color: #F59E0B" onclick="filterTable('weak')">
                <div class="stat-icon"><i class="fas fa-triangle-exclamation"></i></div>
                <div class="stat-info">
                    <h3><%= onus.filter(o => parseFloat(o.rx_power) < -25 && o.status === 'Up').length %></h3>
                    <p><%= t.weak_signal %> (< -25dBm)</p>
                </div>
            </div>
        </div>

        <div class="olt-box">
            <div class="tab-bar">
                <button class="active" onclick="switchTab('mon', this)"><i class="fas fa-desktop"></i> <%= t.monitor_onu %></button>
                <button onclick="switchTab('cfg', this)"><i class="fas fa-cog"></i> <%= t.manage_olt_device %></button>
            </div>

            <div id="tab-mon" class="tab-pane active">
                <div style="display:flex; justify-content:space-between; margin-bottom:20px; gap:20px;">
                    <div style="position:relative; max-width:400px; flex:1;">
                        <i class="fas fa-search" style="position:absolute; left:15px; top:50%; transform:translateY(-50%); color:var(--muted);"></i>
                        <input type="text" id="onuSearch" class="form-control" placeholder="<%= t.search_onu_placeholder %>" style="padding-left:45px;">
                    </div>
                </div>

                <div class="table-container">
                    <table id="onuTable">
                        <thead>
                            <tr>
                                <th><%= t.olt %> Brand</th>
                                <th>Index</th>
                                <th>Serial Number</th>
                                <th>MAC Address</th>
                                <th><%= t.user_label || 'User' %> / <%= t.name_label %></th>
                                <th>TX Power</th>
                                <th>RX Signal</th>
                                <th><%= t.status %></th>
                                <th><%= t.last_sync %></th>
                                <th><%= t.action %></th>
                            </tr>
                        </thead>
                        <tbody>
                        <% if(onus.length > 0) { %>
                            <% onus.forEach(o => { %>
                            <tr class="onu-row">
                                <td>
                                    <span class="badge" style="background:rgba(255,255,255,0.05); color:var(--text); font-size:10px;">
                                        <%= o.olt_brand || 'HIOSO' %>
                                    </span>
                                    <div style="color:var(--muted); font-size:11px; margin-top:4px;"><%= o.olt_name %></div>
                                </td>
                                <td><code><%= o.onu_index %></code></td>
                                <td style="font-family:monospace; font-size:12px;">
                                    <% if(o.olt_brand === 'ZTE' && o.sn) { %>
                                        <%= o.sn %>
                                    <% } else { %>
                                        <span style="color:var(--muted);">-</span>
                                    <% } %>
                                </td>
                                <td style="font-family:monospace; font-size:12px;">
                                    <%= o.mac || '-' %>
                                </td>
                                <td style="font-weight:700; color:var(--text);">
                                    <%= o.name %> 
                                    <i class="fas fa-edit" style="color:var(--muted); font-size:10px; cursor:pointer;" onclick="editName('<%= o.olt_id %>', '<%= o.onu_index %>', '<%= o.name %>')"></i>
                                </td>
                                <td><%= o.tx_power %> dBm</td>
                                <td>
                                    <% let rx = parseFloat(o.rx_power); %>
                                    <span class="sig-badge <%= rx < -27 ? 'sig-bad' : (rx < -25 ? 'sig-warn' : 'sig-good') %>" data-sig="<%= rx < -25 ? 'weak' : 'good' %>">
                                        <%= o.rx_power %> dBm
                                    </span>
                                </td>
                                <td>
                                    <span class="status-badge <%= o.status === 'Up' ? 'status-up' : 'status-down' %>">
                                        <i class="fas <%= o.status === 'Up' ? 'fa-check-circle' : 'fa-times-circle' %>"></i>
                                        <%= o.status === 'Up' ? t.online : t.offline %>
                                    </span>
                                </td>
                                <td style="font-size:12px; color:var(--muted);"><%= new Date(o.last_updated).toLocaleString(lang === 'id' ? 'id-ID' : 'en-US') %></td>
                                <td>
                                    <div style="display:flex;gap:12px;">
                                        <button class="btn-action" title="<%= t.edit %>" onclick="editName('<%= o.olt_id %>', '<%= o.onu_index %>', '<%= o.name %>')"><i class="fas fa-edit"></i></button>
                                        <button class="btn-action" title="Config VLAN" onclick="openOnuConfig('<%= o.olt_id %>', '<%= o.onu_index %>', '<%= o.name %>')"><i class="fas fa-network-wired"></i></button>
                                        <button class="btn-action danger" title="<%= t.reboot_onu %>" onclick="rebootOnu(<%= o.olt_id %>, '<%= o.onu_index %>')"><i class="fas fa-power-off"></i></button>
                                    </div>
                                </td>
                            </tr>
                            <% }); %>
                        <% } else { %>
                            <tr><td colspan="10" style="text-align:center; padding:100px; color:var(--muted);"><%= t.no_olt_data %></td></tr>
                        <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

            <div id="tab-cfg" class="tab-pane">
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
                    <h3 style="margin:0; font-size:16px;"><%= t.olt_config %></h3>
                    <button class="btn btn-primary btn-sm" onclick="openAddModal()">+ <%= t.add_olt %></button>
                </div>
                <div class="table-container">
                    <table>
                        <thead>
                            <tr>
                                <th>Brand & Model / OLT</th>
                                <th>Host / IP</th>
                                <th>SNMP</th>
                                <th>Web API</th>
                                <th><%= t.action %></th>
                            </tr>
                        </thead>
                        <tbody>
                            <% olts.forEach(o => { %>
                            <tr>
                                <td style="font-weight:700;">
                                    <%= o.name %>
                                    <div style="font-size:11px; font-weight:normal; color:var(--muted);"><%= o.brand || 'HIOSO' %> - <%= o.model || 'Universal' %></div>
                                </td>
                                <td><code><%= o.host %></code></td>
                                <td><span class="badge" style="background:rgba(255,255,255,0.05); color:var(--text);"><%= o.community %></span></td>
                                <td><span style="font-size:12px; color:var(--muted);"><%= o.web_user %> / ****</span></td>
                                <td>
                                    <div style="display:flex; gap:12px;">
                                        <button class="btn-action" title="Test Connection" onclick="testOLT('<%= o.host %>', '<%= o.community %>')"><i class="fas fa-plug"></i></button>
                                        <button class="btn-action" onclick='openEditModal(<%- JSON.stringify(o) %>)'><i class="fas fa-edit"></i></button>
                                        <button class="btn-action danger" onclick="deleteOlt(<%= o.id %>)"><i class="fas fa-trash"></i></button>
                                    </div>
                                </td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</main>

<!-- MODALS -->
<div class="modal-overlay" id="nameModal" onclick="if(event.target===this)this.style.display='none'">
    <div class="modal-card">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
            <h3 style="margin:0;"><%= t.change_onu_name %></h3>
            <button class="btn-action" onclick="document.getElementById('nameModal').style.display='none'"><i class="fas fa-times"></i></button>
        </div>
        <input type="hidden" id="editOltId">
        <input type="hidden" id="editOnuIndex">
        <div class="form-group">
            <label><%= t.name_label %></label>
            <input type="text" id="newName" class="form-control" placeholder="<%= t.onu_name_id_placeholder %>">
        </div>
        <div style="display:flex; justify-content:flex-end; gap:10px; margin-top:20px;">
            <button class="btn" style="background:rgba(255,255,255,0.05);" onclick="document.getElementById('nameModal').style.display='none'"><%= t.cancel %></button>
            <button class="btn btn-primary" onclick="saveName()"><%= t.save_changes %></button>
        </div>
    </div>
</div>

<div class="modal-overlay" id="oltModal" onclick="if(event.target===this)this.style.display='none'">
    <div class="modal-card">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
            <h3 id="oltModalTitle" style="margin:0;"><%= t.add_new_olt %></h3>
            <button class="btn-action" onclick="document.getElementById('oltModal').style.display='none'"><i class="fas fa-times"></i></button>
        </div>
        <form id="oltForm">
            <input type="hidden" id="oId">
            <div class="form-group"><label><%= t.identity_name %></label><input type="text" id="oName" class="form-control" required placeholder="<%= t.example_olt_name %>"></div>
            
            <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:15px; margin-bottom:15px;">
                <div class="form-group" style="margin-bottom:0;">
                    <label>Host / IP</label>
                    <input type="text" id="oHost" class="form-control" required placeholder="192.168.x.x">
                </div>
                <div class="form-group" style="margin-bottom:0;">
                    <label>Brand OLT</label>
                    <select id="oBrand" class="form-control" onchange="updateModels()">
                        <option value="HIOSO">HIOSO / C-Data</option>
                        <option value="ZTE">ZTE</option>
                        <option value="Huawei">Huawei</option>
                        <option value="VSOL">VSOL</option>
                        <option value="HSGQ">HSGQ</option>
                    </select>
                </div>
                <div class="form-group" style="margin-bottom:0;">
                    <label>Tipe / Seri OLT</label>
                    <select id="oModel" class="form-control">
                        <!-- Populated by JS -->
                    </select>
                </div>
            </div>

            <div class="form-group"><label>SNMP Community</label><input type="text" id="oCommunity" class="form-control" value="public"></div>
            <div style="background:rgba(255,255,255,0.02); padding:22px; border-radius:20px; border:1px solid var(--border); margin-bottom:25px;">
                <p style="font-size:11px; text-transform:uppercase; letter-spacing:1px; font-weight:800; margin:0 0 15px; color:var(--primary); display:flex; align-items:center; gap:8px;">
                    <i class="fas fa-shield-alt"></i> <%= t.web_credentials || 'Kredensial Web (untuk Reboot)' %>
                </p>
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px;">
                    <input type="text" id="oWebUser" class="form-control" placeholder="Username" value="admin">
                    <input type="password" id="oWebPass" class="form-control" placeholder="Password">
                </div>
            </div>
            <div style="margin-bottom:20px;">
                <button type="button" class="btn" style="background:rgba(59,130,246,0.1); color:var(--primary); border:1px solid rgba(59,130,246,0.2); width:100%; height:45px; border-radius:12px; font-weight:600; justify-content:center; gap:10px;" onclick="testOLTModal()">
                    <i class="fas fa-plug"></i> <%= t.test_connection || 'Test Connection' %>
                </button>
            </div>
            <div style="display:flex; gap:12px; margin-top:10px;">
                <button type="submit" class="btn btn-primary" style="flex:1; height:48px; border-radius:14px; font-weight:700; font-size:15px; justify-content:center;">
                    <i class="fas fa-save"></i> <%= t.save_device %>
                </button>
                <button type="button" class="btn" style="background:rgba(255,255,255,0.05); border:1px solid var(--border); height:48px; border-radius:14px; padding:0 25px; font-weight:600;" onclick="document.getElementById('oltModal').style.display='none'">
                    <%= t.cancel %>
                </button>
            </div>
        </form>
    </div>
</div>

<div class="modal-overlay" id="onuConfigModal" onclick="if(event.target===this)this.style.display='none'">
    <div class="modal-card">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
            <h3 style="margin:0;">Config ONU: <span id="configOnuName"></span></h3>
            <button class="btn-action" onclick="document.getElementById('onuConfigModal').style.display='none'"><i class="fas fa-times"></i></button>
        </div>
        <input type="hidden" id="configOltId">
        <input type="hidden" id="configOnuIndex">
        
        <div class="form-group" style="margin-bottom:20px;">
            <label>VLAN ID (PVID)</label>
            <input type="number" id="vlanId" class="form-control" placeholder="Contoh: 100" min="1" max="4094">
            <p style="font-size:11px; color:var(--muted); margin-top:8px;">* Saat ini hanya didukung untuk OLT HIOSO (EPON/GPON).</p>
        </div>

        <div style="display:flex; gap:12px; margin-top:10px;">
            <button type="button" class="btn btn-primary" style="flex:1; height:48px; border-radius:14px; font-weight:700; font-size:15px; justify-content:center;" onclick="saveOnuConfig()">
                <i class="fas fa-save"></i> <%= t.save_changes %>
            </button>
            <button type="button" class="btn" style="background:rgba(255,255,255,0.05); border:1px solid var(--border); height:48px; border-radius:14px; padding:0 25px; font-weight:600;" onclick="document.getElementById('onuConfigModal').style.display='none'">
                <%= t.cancel %>
            </button>
        </div>
    </div>
</div>

<div class="toast" id="toast"></div>

<script>
function switchTab(id, btn) {
    document.querySelectorAll('.tab-pane').forEach(c => c.classList.remove('active'));
    document.querySelectorAll('.tab-bar button').forEach(b => b.classList.remove('active'));
    document.getElementById('tab-' + id).classList.add('active');
    btn.classList.add('active');
}

function filterTable(q) {
    const rows = document.querySelectorAll('.onu-row');
    rows.forEach(r => {
        if (q === 'weak') {
            const sig = r.querySelector('[data-sig]').dataset.sig;
            r.style.display = (sig === 'weak' && r.innerText.includes('Online')) ? '' : 'none';
        } else {
            r.style.display = r.innerText.toLowerCase().includes(q.toLowerCase()) ? '' : 'none';
        }
    });
}
document.getElementById('onuSearch').addEventListener('input', e => filterTable(e.target.value));

async function syncOLT() {
    const btn = event.currentTarget;
    const oldHtml = btn.innerHTML;
    btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Syncing...';
    showToast('<%= t.pulling_snmp_data %>', 'info');
    try {
        const res = await fetch('/olt/api/sync', { 
            method: 'POST',
            signal: AbortSignal.timeout(180000) // 3 minutes timeout
        });
        const d = await res.json();
        showToast(d.message, d.success ? 'success' : 'error');
        if(d.success) {
            setTimeout(() => location.reload(), 1500);
        }
    } catch(e) { 
        showToast('<%= t.sync_failed_timeout %>: ' + e.message, 'error'); 
    } finally {
        btn.disabled = false;
        btn.innerHTML = oldHtml;
    }
}

function editName(oltId, index, name) {
    document.getElementById('editOltId').value = oltId;
    document.getElementById('editOnuIndex').value = index;
    document.getElementById('newName').value = name;
    document.getElementById('nameModal').style.display = 'flex';
}

function openAddModal() {
    document.getElementById('oltModalTitle').innerText = '<%= t.add_new_olt %>';
    document.getElementById('oId').value = '';
    document.getElementById('oName').value = '';
    document.getElementById('oHost').value = '';
    document.getElementById('oBrand').value = 'HIOSO';
    updateModels(); // Populate default
    document.getElementById('oCommunity').value = 'public';
    document.getElementById('oltModal').style.display = 'flex';
}

function openEditModal(o) {
    document.getElementById('oltModalTitle').innerText = '<%= t.edit %> OLT: ' + o.name;
    document.getElementById('oId').value = o.id;
    document.getElementById('oName').value = o.name;
    document.getElementById('oHost').value = o.host;
    document.getElementById('oBrand').value = o.brand || 'HIOSO';
    updateModels(o.model); // Populate and select current model
    document.getElementById('oCommunity').value = o.community;
    document.getElementById('oWebUser').value = o.web_user;
    document.getElementById('oWebPass').value = o.web_password;
    document.getElementById('oltModal').style.display = 'flex';
}

document.getElementById('oltForm').addEventListener('submit', async e => {
    e.preventDefault();
    const id = document.getElementById('oId').value;
    const body = {
        name: document.getElementById('oName').value,
        host: document.getElementById('oHost').value,
        port: 161,
        community: document.getElementById('oCommunity').value,
        brand: document.getElementById('oBrand').value,
        model: document.getElementById('oModel').value,
        web_user: document.getElementById('oWebUser').value,
        web_password: document.getElementById('oWebPass').value,
        status: 'active'
    };
    const res = await fetch(id ? '/olt/api/olts/'+id : '/olt/api/olts', { 
        method: id ? 'PUT' : 'POST', 
        headers: {'Content-Type':'application/json'}, 
        body: JSON.stringify(body) 
    });
    if((await res.json()).success) location.reload();
});

async function deleteOlt(id) {
    if(!confirm('<%= t.confirm_delete_olt %>')) return;
    const res = await fetch('/olt/api/olts/' + id, { method: 'DELETE' });
    const data = await res.json();
    if(data.success) location.reload();
}

function openOnuConfig(oltId, index, name) {
    document.getElementById('configOltId').value = oltId;
    document.getElementById('configOnuIndex').value = index;
    document.getElementById('configOnuName').innerText = name;
    document.getElementById('vlanId').value = '';
    document.getElementById('onuConfigModal').style.display = 'flex';
}

async function saveOnuConfig() {
    const oltId = document.getElementById('configOltId').value;
    const index = document.getElementById('configOnuIndex').value;
    const vlanId = document.getElementById('vlanId').value;

    if(!vlanId) return showToast('Masukkan VLAN ID!', 'error');

    showToast('⏳ Sedang mengatur VLAN...', 'info');
    try {
        const res = await fetch('/olt/api/onu/vlan', {
            method: 'POST',
            headers: {'Content-Type':'application/json'},
            body: JSON.stringify({ olt_id: oltId, index: index, vlan_id: vlanId })
        });
        const d = await res.json();
        showToast(d.message, d.success ? 'success' : 'error');
        if(d.success) {
            document.getElementById('onuConfigModal').style.display = 'none';
        }
    } catch(e) {
        showToast('Error: ' + e.message, 'error');
    }
}

async function rebootOnu(oltId, index) {
    if(!confirm('<%= t.reboot_onu_confirm %> ' + index + '?')) return;
    showToast('<%= t.sending_reboot_command %>', 'info');
    const res = await fetch('/olt/api/reboot', {
        method: 'POST',
        headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ olt_id: oltId, index: index })
    });
    const d = await res.json();
    showToast(d.message, d.success ? 'success' : 'error');
}

function showToast(m, t) {
    const toast = document.getElementById('toast');
    toast.textContent = m;
    toast.style.borderLeftColor = t === 'error' ? '#ef4444' : (t === 'info' ? '#3b82f6' : '#10b981');
    toast.style.display = 'block';
    setTimeout(() => toast.style.display = 'none', 5000);
}

async function testOLT(host, community) {
    if (!host) return;
    showToast('⏳ Testing SNMP connection to ' + host + '...', 'info');
    try {
        const res = await fetch('/olt/api/test', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ host, community })
        });
        const d = await res.json();
        showToast(d.message, d.success ? 'success' : 'error');
    } catch (e) {
        showToast('Error: ' + e.message, 'error');
    }
}

async function testOLTModal() {
    const host = document.getElementById('oHost').value;
    const community = document.getElementById('oCommunity').value;
    if (!host) return showToast('Masukkan Host / IP OLT!', 'error');
    testOLT(host, community);
}

const brandModels = {
    'HIOSO': ['HA7304', 'HA7308', 'HA7004', 'Universal'],
    'ZTE': ['C320', 'C300', 'C600', 'C610', 'Universal'],
    'Huawei': ['MA5608T', 'MA5680T', 'MA5683T', 'MA5800-X2', 'MA5800-X7', 'Universal'],
    'VSOL': ['V1600D4', 'V1600D8', 'V1600G1', 'V1600G2', 'Universal'],
    'HSGQ': ['G008', 'G016', 'Universal']
};

function updateModels(selectedModel = null) {
    const brand = document.getElementById('oBrand').value;
    const modelSelect = document.getElementById('oModel');
    modelSelect.innerHTML = '';
    
    if (brandModels[brand]) {
        brandModels[brand].forEach(m => {
            const opt = document.createElement('option');
            opt.value = m;
            opt.textContent = m;
            if (m === selectedModel) opt.selected = true;
            modelSelect.appendChild(opt);
        });
    }
}
</script>
</body>
</html>
