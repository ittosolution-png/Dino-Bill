<head>
    <%- include('partials/head') %>
    <style>
        .plugin-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 20px;
            margin-top: 20px;
        }

        .plugin-card {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 24px;
            display: flex;
            flex-direction: column;
            gap: 16px;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        .plugin-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 40px rgba(0,0,0,0.3);
            border-color: var(--primary);
        }

        .plugin-icon {
            width: 50px;
            height: 50px;
            background: var(--primary-soft);
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--primary);
            font-size: 24px;
        }

        .plugin-status {
            position: absolute;
            top: 24px;
            right: 24px;
        }

        .plugin-name {
            font-size: 18px;
            font-weight: 700;
            margin: 0;
        }

        .plugin-desc {
            font-size: 14px;
            color: var(--muted);
            line-height: 1.6;
            flex-grow: 1;
        }

        .license-box {
            background: rgba(0,0,0,0.2);
            border-radius: 12px;
            padding: 12px;
            display: none;
            margin-top: 10px;
        }

        .license-box.active {
            display: block;
        }

        .plugin-footer {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-top: 10px;
        }

        .expiry-tag {
            font-size: 12px;
            color: var(--warning);
        }
    </style>
</head>

<body>
    <%- include('partials/sidebar') %>
    <main class="main">
        <%- include('partials/topbar', { title: 'Plugin & Add-ons' }) %>
        <div class="content">
            <div class="page-header">
                <div>
                    <h1 class="page-title">Fitur Tambahan</h1>
                    <p style="color:var(--muted); font-size:14px">Aktifkan fitur premium untuk meningkatkan efisiensi operasional Anda.</p>
                </div>
            </div>

            <div class="plugin-grid">
                <% plugins.forEach(plugin => { %>
                    <div class="plugin-card">
                        <div class="plugin-status">
                            <span class="badge badge-<%= plugin.is_active ? 'active' : 'isolated' %>">
                                <%= plugin.is_active ? 'Aktif' : 'Tersedia' %>
                            </span>
                        </div>
                        <div class="plugin-icon">
                            <% if(plugin.plugin_key === 'wa_bulk') { %> 📱 
                            <% } else if(plugin.plugin_key === 'network_monitor') { %> 📊
                            <% } else { %> 🧩 <% } %>
                        </div>
                        <div>
                            <h3 class="plugin-name"><%= plugin.name %></h3>
                            <p class="plugin-desc"><%= plugin.description %></p>
                        </div>

                        <% if (plugin.is_active) { %>
                            <div class="license-box active">
                                <div style="font-size:11px; color:var(--muted)">LICENSE KEY</div>
                                <code style="font-size:13px; color:var(--primary)"><%= plugin.license_key %></code>
                            </div>
                            <button class="btn btn-danger" onclick="deactivatePlugin(<%= plugin.id %>)" style="width:100%; justify-content:center">Nonaktifkan</button>
                        <% } else { %>
                            <div id="activateBox-<%= plugin.id %>" class="license-box">
                                <input type="text" id="license-<%= plugin.id %>" class="form-control" placeholder="Input License Key (DINO-XXXX)">
                                <button class="btn btn-primary" onclick="submitActivation(<%= plugin.id %>)" style="width:100%; margin-top:10px; justify-content:center">Kirim Kode</button>
                            </div>
                            <button id="btnShow-<%= plugin.id %>" class="btn btn-primary" onclick="showActivate(<%= plugin.id %>)" style="width:100%; justify-content:center">Aktifkan Sekarang</button>
                        <% } %>
                    </div>
                <% }) %>
            </div>
        </div>
    </main>

    <div class="toast" id="toast"></div>

    <script>
        function showActivate(id) {
            document.getElementById('activateBox-' + id).classList.add('active');
            document.getElementById('btnShow-' + id).style.display = 'none';
        }

        async function submitActivation(id) {
            const key = document.getElementById('license-' + id).value;
            if(!key) return showToast('Masukkan kode lisensi!', 'error');

            try {
                const res = await fetch('/plugins/activate/' + id, {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({ license_key: key })
                });
                const data = await res.json();
                showToast(data.message, data.success ? 'success' : 'error');
                if(data.success) setTimeout(() => location.reload(), 1000);
            } catch (e) {
                showToast('Gagal memproses aktivasi', 'error');
            }
        }

        async function deactivatePlugin(id) {
            if(!confirm('Apakah Anda yakin ingin menonaktifkan plugin ini?')) return;
            try {
                const res = await fetch('/plugins/deactivate/' + id, { method: 'POST' });
                const data = await res.json();
                showToast(data.message, data.success ? 'success' : 'error');
                if(data.success) setTimeout(() => location.reload(), 1000);
            } catch (e) {
                showToast('Gagal memproses data', 'error');
            }
        }

        function showToast(msg, type) {
            const t = document.getElementById('toast');
            t.textContent = msg;
            t.style.borderColor = type === 'success' ? '#10B981' : '#EF4444';
            t.style.color = type === 'success' ? '#10B981' : '#EF4444';
            t.classList.add('show');
            setTimeout(() => t.classList.remove('show'), 3000);
        }
    </script>
</body>
