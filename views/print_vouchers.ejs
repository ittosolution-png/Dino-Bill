<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Cetak Voucher - Dino-Bill</title>
    <style>
        body { font-family: 'Courier New', Courier, monospace; margin: 0; padding: 20px; background: white; color: black; }
        .voucher-container { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 10px; }
        .voucher-box { border: 2px dashed #000; padding: 10px; text-align: center; position: relative; page-break-inside: avoid; }
        .brand { font-weight: bold; font-size: 14px; border-bottom: 1px solid #000; margin-bottom: 5px; padding-bottom: 2px; }
        .code-label { font-size: 10px; text-transform: uppercase; margin-top: 5px; }
        .code-value { font-size: 20px; font-weight: bold; margin: 5px 0; letter-spacing: 1px; }
        .price { font-weight: bold; font-size: 12px; }
        .footer { font-size: 9px; margin-top: 8px; font-style: italic; }
        @media print {
            .no-print { display: none; }
            body { padding: 0; }
            .voucher-container { gap: 5px; }
        }
    </style>
</head>
<body>
    <div class="no-print" style="margin-bottom: 20px; padding: 10px; background: #f0f0f0; border: 1px solid #ccc; display: flex; justify-content: space-between; align-items: center;">
        <span>Siap mencetak <strong><%= vouchers.length %></strong> voucher.</span>
        <button onclick="window.print()" style="padding: 8px 16px; cursor: pointer; font-weight: bold;">Cetak Sekarang (Ctrl+P)</button>
    </div>

    <div class="voucher-container">
        <% vouchers.forEach(v => { %>
        <div class="voucher-box">
            <div class="brand">🦖 DINO-NET</div>
            <div class="code-label">Username / Kode Voucher:</div>
            <div class="code-value"><%= v.code %></div>
            <div class="price">Rp <%= parseFloat(v.price).toLocaleString('id-ID') %></div>
            <div class="footer">Paket: <%= v.profile %></div>
            <div style="font-size: 8px; color: #666; margin-top: 2px;">Terima kasih telah berlangganan</div>
        </div>
        <% }); %>
    </div>
</body>
</html>
