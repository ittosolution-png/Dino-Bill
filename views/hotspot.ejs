<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('partials/head') %>
    <style>
        .stats-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:20px;margin-bottom:24px;}
        .stat-card{background:var(--card-bg);border:1px solid var(--border);border-radius:16px;padding:20px;display:flex;align-items:center;gap:16px;}
        .stat-icon{width:48px;height:48px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:20px;}
        .stat-icon.blue{background:rgba(59,130,246,.1);color:#60A5FA;}
        .stat-icon.green{background:rgba(16,185,129,.1);color:#34D399;}
        .stat-icon.orange{background:rgba(245,158,11,.1);color:#FBBF24;}
        .stat-value{font-size:20px;font-weight:700;margin:0;}
        .stat-label{font-size:12px;color:var(--muted);margin:0;}
        .badge-online{background:rgba(16,185,129,.1);color:var(--success);border:1px solid rgba(16,185,129,.2);}
        .badge-offline{background:rgba(156,163,175,.1);color:var(--muted);border:1px solid rgba(156,163,175,.2);}
        .overlay{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.7);backdrop-filter:blur(4px);display:none;align-items:center;justify-content:center;z-index:999;}
        .modal{background:#111827;border:1px solid var(--border);border-radius:20px;width:100%;max-width:480px;padding:28px;}
        .modal-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;}.modal-title{font-size:18px;font-weight:600;margin:0;}.close-btn{background:none;border:none;color:var(--muted);font-size:22px;cursor:pointer;}
        .form-group{margin-bottom:14px;}.form-group label{display:block;margin-bottom:6px;font-size:13px;color:var(--muted);}
        .toast{position:fixed;bottom:24px;right:24px;background:#111827;border:1px solid var(--border);border-radius:12px;padding:14px 20px;z-index:9999;display:none;font-size:14px;}.toast.show{display:block;}
    </style>
</head>
<body>
<%- include('partials/sidebar') %>
<main class="main">
    <%- include('partials/topbar', { title: 'Hotspot Management' }) %>
    <div class="content">
        <div class="page-header">
            <h1 class="page-title">MikroTik Hotspot</h1>
            <div style="display:flex;gap:25px;align-items:center;margin-bottom:10px">
                <button class="btn btn-primary" onclick="openModal('profile')">Profile Hotspot</button>
                <button class="btn btn-primary" onclick="openModal('user')">+ Tambah User</button>
            </div>
        </div>

        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon blue">👥</div>
                <div><p class="stat-value"><%= users.length %></p><p class="stat-label">Total User</p></div>
            </div>
            <div class="stat-card">
                <div class="stat-icon green">●</div>
                <div><p class="stat-value"><%= users.filter(u => u.uptime !== '0s' && !u.disabled).length %></p><p class="stat-label">Online</p></div>
            </div>
            <div class="stat-card">
                <div class="stat-icon orange">⚡</div>
                <div><p class="stat-value"><%= profiles.length %></p><p class="stat-label">Profiles</p></div>
            </div>
        </div>

        <div class="card">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:15px">
                <h3 style="margin:0;font-size:16px">Daftar User Hotspot</h3>
                <input type="text" class="form-control" placeholder="Cari user..." style="width:200px" id="userSearch">
            </div>
            <table>
                <thead><tr><th>Username</th><th>Profile</th><th>Uptime</th><th>Address</th><th>Status</th><th>Aksi</th></tr></thead>
                <tbody id="userTable">
                <% if(users.length > 0) { %>
                    <% users.forEach(u => { %>
                    <tr>
                        <td style="font-weight:600"><%= u.name %></td>
                        <td><span class="badge" style="background:rgba(139,92,246,.1);color:var(--secondary)"><%= u.profile %></span></td>
                        <td><%= u.uptime || '-' %></td>
                        <td><code><%= u.address || '-' %></code></td>
                        <td>
                            <% if(u.disabled) { %><span class="badge" style="background:rgba(239,68,68,.1);color:var(--danger)">Disabled</span>
                            <% } else if(u.uptime !== '0s') { %><span class="badge badge-online">Online</span>
                            <% } else { %><span class="badge badge-offline">Offline</span><% } %>
                        </td>
                        <td>
                            <div style="display:flex;gap:10px">
                                <button class="btn btn-sm btn-info" onclick='openEditModal(<%- JSON.stringify(u) %>)'>Edit</button>
                                <button class="btn btn-sm btn-danger" onclick="deleteUser('<%= u.name %>')">Hapus</button>
                            </div>
                        </td>
                    </tr>
                    <% }); %>
                <% } else { %>
                    <tr><td colspan="6" style="text-align:center;color:var(--muted);padding:40px">Tidak ada data user hotspot.</td></tr>
                <% } %>
                </tbody>
            </table>
        </div>
    </div>
</main>

<!-- Modals -->
<div class="overlay" id="modalOverlay" onclick="if(event.target===this)closeModal()">
    <div class="modal" onclick="event.stopPropagation()">
        <div class="modal-header"><h2 class="modal-title" id="modalTitle">Tambah User</h2><button class="close-btn" onclick="closeModal()">×</button></div>
        <form id="hotspotForm">
            <input type="hidden" id="formType">
            <div id="userFields">
                <div class="form-group"><label>Username</label><input type="text" id="hUser" class="form-control" placeholder="Username"></div>
                <div class="form-group"><label>Password</label><input type="text" id="hPass" class="form-control" placeholder="Password"></div>
                <div class="form-group">
                    <label>Profile</label>
                    <select id="hProfile" class="form-control">
                        <% profiles.forEach(p => { %>
                            <option value="<%= p.name %>"><%= p.name %></option>
                        <% }) %>
                    </select>
                </div>
            </div>
            <div id="profileFields" style="display:none">
                <div class="form-group"><label>Nama Profile</label><input type="text" id="pName" class="form-control" placeholder="cth: 2mbps"></div>
                <div class="form-group"><label>Rate Limit (Upload/Download)</label><input type="text" id="pRate" class="form-control" placeholder="cth: 1M/2M"></div>
                <div class="form-group"><label>Shared Users</label><input type="number" id="pShared" class="form-control" value="1"></div>
            </div>
            <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;margin-top:10px">Simpan</button>
        </form>
    </div>
</div>

<div class="toast" id="toast"></div>

<script>
function showToast(msg,type){const t=document.getElementById('toast');t.textContent=msg;t.style.borderColor=type==='success'?'rgba(16,185,129,.4)':'rgba(239,68,68,.4)';t.style.color=type==='success'?'#10B981':'#EF4444';t.classList.add('show');setTimeout(()=>t.classList.remove('show'),3500);}

function openModal(type) {
    document.getElementById('formType').value = type;
    document.getElementById('modalTitle').textContent = type === 'user' ? 'Tambah User Hotspot' : 'Tambah Profile Hotspot';
    document.getElementById('userFields').style.display = type === 'user' ? 'block' : 'none';
    document.getElementById('profileFields').style.display = type === 'profile' ? 'block' : 'none';
    document.getElementById('modalOverlay').style.display = 'flex';
}

function closeModal() {
    document.getElementById('modalOverlay').style.display = 'none';
    document.getElementById('hotspotForm').reset();
}

document.getElementById('userSearch').addEventListener('input', function(e) {
    const q = e.target.value.toLowerCase();
    const rows = document.querySelectorAll('#userTable tr');
    rows.forEach(r => {
        r.style.display = r.textContent.toLowerCase().includes(q) ? '' : 'none';
    });
});

document.getElementById('hotspotForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const type = document.getElementById('formType').value;
    
    if (type === 'user') {
        const body = {
            username: document.getElementById('hUser').value,
            password: document.getElementById('hPass').value,
            profile: document.getElementById('hProfile').value
        };
        const res = await fetch('/hotspot/api/user/add', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify(body)
        });
        const d = await res.json();
        showToast(d.message, d.success ? 'success' : 'error');
        if (d.success) { closeModal(); setTimeout(() => location.reload(), 1000); }
    } else {
        const body = {
            name: document.getElementById('pName').value,
            rateLimit: document.getElementById('pRate').value,
            sharedUsers: document.getElementById('pShared').value
        };
        const res = await fetch('/hotspot/api/profile/add', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify(body)
        });
        const d = await res.json();
        showToast(d.message, d.success ? 'success' : 'error');
        if (d.success) { closeModal(); setTimeout(() => location.reload(), 1000); }
    }
});

async function deleteUser(name) {
    if (!confirm('Hapus user hotspot "' + name + '" dari MikroTik?')) return;
    const res = await fetch('/hotspot/api/user/' + encodeURIComponent(name), { method: 'DELETE' });
    const d = await res.json();
    showToast(d.message, d.success ? 'success' : 'error');
    if (d.success) setTimeout(() => location.reload(), 1000);
}
</script>
</body>
</html>
