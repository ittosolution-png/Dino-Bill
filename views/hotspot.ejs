<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('partials/head') %>
    <!-- Use SweetAlert2 for modern modals -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        /* Glassmorphism Theme Variables */
        :root {
            --glass-bg: rgba(30, 41, 59, 0.7);
            --glass-border: rgba(255, 255, 255, 0.1);
            --glass-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.3);
            --table-hover: rgba(255, 255, 255, 0.05);
        }

        .stats-grid {
            display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); 
            gap: 20px; margin-bottom: 30px;
        }

        .stat-card {
            background: var(--glass-bg); border: 1px solid var(--glass-border);
            border-radius: 20px; padding: 24px; display: flex; align-items: center; 
            gap: 20px; backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
            box-shadow: var(--glass-shadow); transition: transform 0.3s, box-shadow 0.3s;
            position: relative; overflow: hidden;
        }
        
        .stat-card::before {
            content: ''; position: absolute; top: -50%; left: -50%; width: 200%; height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.05) 0%, transparent 60%);
            opacity: 0; transition: opacity 0.5s; pointer-events: none;
        }

        .stat-card:hover { transform: translateY(-5px); box-shadow: 0 12px 40px rgba(0,0,0,0.4); }
        .stat-card:hover::before { opacity: 1; }

        .stat-icon {
            width: 56px; height: 56px; border-radius: 16px; display: flex; 
            align-items: center; justify-content: center; font-size: 24px;
            box-shadow: inset 0 2px 10px rgba(255,255,255,0.1);
        }
        .stat-icon.blue { background: linear-gradient(135deg, rgba(59,130,246,0.2), rgba(37,99,235,0.4)); color: #60A5FA; border: 1px solid rgba(96,165,250,0.3); }
        .stat-icon.green { background: linear-gradient(135deg, rgba(16,185,129,0.2), rgba(5,150,105,0.4)); color: #34D399; border: 1px solid rgba(52,211,153,0.3); }
        .stat-icon.orange { background: linear-gradient(135deg, rgba(245,158,11,0.2), rgba(217,119,6,0.4)); color: #FBBF24; border: 1px solid rgba(251,191,36,0.3); }
        
        .stat-value { font-size: 28px; font-weight: 800; margin: 0; color: var(--text); letter-spacing: -0.5px; }
        .stat-label { font-size: 13px; color: var(--muted); margin: 4px 0 0 0; text-transform: uppercase; letter-spacing: 1px; font-weight: 600; }

        /* Modern Table Card */
        .glass-card {
            background: var(--glass-bg); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
            border: 1px solid var(--glass-border); border-radius: 20px; box-shadow: var(--glass-shadow);
            padding: 24px; overflow: hidden;
        }

        .table-header {
            display: flex; justify-content: space-between; align-items: center; 
            margin-bottom: 24px; flex-wrap: wrap; gap: 15px;
        }

        .table-title { margin: 0; font-size: 18px; font-weight: 700; display: flex; align-items: center; gap: 10px; }
        .table-title i { color: var(--primary); }

        /* Modern Search Input */
        .search-box {
            position: relative; width: 280px;
        }
        .search-box i {
            position: absolute; left: 16px; top: 50%; transform: translateY(-50%);
            color: var(--muted); pointer-events: none; transition: color 0.3s;
        }
        .search-box input {
            width: 100%; padding: 12px 16px 12px 42px; border-radius: 12px;
            background: rgba(0,0,0,0.2); border: 1px solid rgba(255,255,255,0.1);
            color: var(--text); font-size: 14px; transition: all 0.3s;
        }
        .search-box input:focus {
            background: rgba(0,0,0,0.4); border-color: var(--primary);
            box-shadow: 0 0 0 4px rgba(59,130,246,0.1); outline: none;
        }
        .search-box input:focus + i { color: var(--primary); }

        /* Table Styling */
        table { width: 100%; border-collapse: separate; border-spacing: 0; }
        th { 
            text-align: left; padding: 16px 20px; color: var(--muted); 
            font-size: 12px; text-transform: uppercase; letter-spacing: 1px; 
            border-bottom: 1px solid var(--glass-border); font-weight: 600;
        }
        td { 
            padding: 16px 20px; border-bottom: 1px solid rgba(255,255,255,0.03); 
            font-size: 14px; color: var(--text); vertical-align: middle;
        }
        tbody tr { transition: background 0.2s; }
        tbody tr:hover { background: var(--table-hover); }
        tbody tr:last-child td { border-bottom: none; }

        .user-name-cell { display: flex; align-items: center; gap: 12px; font-weight: 600; }
        .user-avatar {
            width: 36px; height: 36px; border-radius: 10px; background: rgba(59,130,246,0.1);
            color: var(--primary); display: flex; align-items: center; justify-content: center;
            font-weight: 700; font-size: 14px; text-transform: uppercase;
        }

        /* Modern Badges */
        .modern-badge {
            padding: 6px 12px; border-radius: 8px; font-size: 12px; font-weight: 600;
            display: inline-flex; align-items: center; gap: 6px;
        }
        .modern-badge::before { content: ''; width: 6px; height: 6px; border-radius: 50%; }
        
        .badge-online { background: rgba(16,185,129,0.1); color: #34D399; border: 1px solid rgba(16,185,129,0.2); }
        .badge-online::before { background: #34D399; box-shadow: 0 0 8px #34D399; }
        
        .badge-offline { background: rgba(100,116,139,0.1); color: #94A3B8; border: 1px solid rgba(100,116,139,0.2); }
        .badge-offline::before { background: #94A3B8; }

        .badge-disabled { background: rgba(239,68,68,0.1); color: #F87171; border: 1px solid rgba(239,68,68,0.2); }
        .badge-disabled::before { background: #F87171; }

        .badge-profile { background: rgba(139,92,246,0.1); color: #A78BFA; border: 1px solid rgba(139,92,246,0.2); }

        /* Action Buttons */
        .action-btns { display: flex; gap: 8px; }
        .btn-icon {
            width: 36px; height: 36px; border-radius: 10px; border: none;
            display: flex; align-items: center; justify-content: center;
            cursor: pointer; transition: all 0.2s; color: white;
        }
        .btn-icon.delete { background: rgba(239,68,68,0.1); color: #F87171; }
        .btn-icon.delete:hover { background: #EF4444; color: white; transform: scale(1.05); }
        
        .btn-icon.info { background: rgba(59,130,246,0.1); color: #60A5FA; }
        .btn-icon.info:hover { background: #3B82F6; color: white; transform: scale(1.05); }

        .ip-code {
            background: rgba(0,0,0,0.3); padding: 4px 8px; border-radius: 6px;
            font-family: monospace; font-size: 13px; color: var(--muted);
            border: 1px solid rgba(255,255,255,0.05);
        }
        
        /* SweetAlert2 Custom Styling for Glassmorphism */
        .swal2-popup.glass-swal {
            background: rgba(30, 41, 59, 0.9) !important;
            backdrop-filter: blur(16px) !important;
            border: 1px solid rgba(255,255,255,0.1) !important;
            border-radius: 24px !important;
            color: #f1f5f9 !important;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5) !important;
        }
        .swal2-title { color: #f8fafc !important; font-weight: 700 !important; }
        .swal2-html-container { color: #cbd5e1 !important; }
        .swal2-input, .swal2-select {
            background: rgba(0,0,0,0.2) !important; border: 1px solid rgba(255,255,255,0.1) !important;
            color: #f1f5f9 !important; border-radius: 12px !important;
        }
        .swal2-input:focus, .swal2-select:focus {
            border-color: #3b82f6 !important; box-shadow: 0 0 0 3px rgba(59,130,246,0.2) !important;
        }
        .swal-label { text-align: left; display: block; margin-bottom: 6px; font-size: 13px; color: #94a3b8; font-weight: 500; }
        .swal-form-group { margin-bottom: 16px; text-align: left; }
    </style>
</head>
<body>
<%- include('partials/sidebar') %>
<main class="main">
    <%- include('partials/topbar', { title: t.hotspot_mgmt }) %>
    <div class="content">
        <div class="page-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
            <div>
                <h1 class="page-title" style="margin: 0; font-size: 28px; font-weight: 800; letter-spacing: -0.5px;">MikroTik Hotspot</h1>
                <p style="color: var(--muted); margin: 5px 0 0 0; font-size: 14px;">Kelola pengguna dan profil hotspot secara real-time</p>
            </div>
            <div style="display:flex; gap: 15px; align-items: center;">
                <button class="btn btn-primary" onclick="addProfileModal()" style="background: rgba(255,255,255,0.1); color: white; border: 1px solid rgba(255,255,255,0.2);">
                    <i class="fas fa-layer-group" style="margin-right: 8px;"></i> <%= t.hotspot_profile %>
                </button>
                <button class="btn btn-primary" onclick="addUserModal()" style="box-shadow: 0 4px 15px rgba(59,130,246,0.4);">
                    <i class="fas fa-user-plus" style="margin-right: 8px;"></i> <%= t.add_user %>
                </button>
            </div>
        </div>

        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon blue"><i class="fas fa-users"></i></div>
                <div>
                    <p class="stat-value"><%= users.length %></p>
                    <p class="stat-label"><%= t.total_user %></p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon green"><i class="fas fa-wifi"></i></div>
                <div>
                    <p class="stat-value"><%= users.filter(u => u.uptime !== '0s' && !u.disabled).length %></p>
                    <p class="stat-label"><%= t.online %></p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon orange"><i class="fas fa-box-open"></i></div>
                <div>
                    <p class="stat-value"><%= profiles.length %></p>
                    <p class="stat-label"><%= t.packages %></p>
                </div>
            </div>
        </div>

        <div class="glass-card">
            <div class="table-header">
                <h3 class="table-title"><i class="fas fa-list-ul"></i> <%= t.hotspot_user_list %></h3>
                <div class="search-box">
                    <input type="text" placeholder="<%= t.search_user_placeholder %>" id="userSearch">
                    <i class="fas fa-search"></i>
                </div>
            </div>
            
            <div style="overflow-x: auto;">
                <table>
                    <thead>
                        <tr>
                            <th><%= t.username %></th>
                            <th>Profile</th>
                            <th>Uptime</th>
                            <th>Address</th>
                            <th><%= t.status %></th>
                            <th style="text-align: right;"><%= t.action %></th>
                        </tr>
                    </thead>
                    <tbody id="userTable">
                    <% if(users.length > 0) { %>
                        <% users.forEach(u => { %>
                        <tr>
                            <td>
                                <div class="user-name-cell">
                                    <div class="user-avatar"><%= u.name.substring(0, 2) %></div>
                                    <%= u.name %>
                                </div>
                            </td>
                            <td><span class="modern-badge badge-profile"><%= u.profile %></span></td>
                            <td style="color: var(--muted); font-weight: 500;"><%= u.uptime || '-' %></td>
                            <td><span class="ip-code"><%= u.address || '-' %></span></td>
                            <td>
                                <% if(u.disabled) { %>
                                    <span class="modern-badge badge-disabled">Disabled</span>
                                <% } else if(u.uptime !== '0s') { %>
                                    <span class="modern-badge badge-online">Online</span>
                                <% } else { %>
                                    <span class="modern-badge badge-offline">Offline</span>
                                <% } %>
                            </td>
                            <td>
                                <div class="action-btns" style="justify-content: flex-end;">
                                    <button class="btn-icon info" onclick="showUserInfo('<%= u.name %>', '<%= u.profile %>', '<%= u.uptime %>', '<%= u.address %>')" title="Detail User">
                                        <i class="fas fa-info-circle"></i>
                                    </button>
                                    <button class="btn-icon delete" onclick="deleteUser('<%= u.name %>')" title="<%= t.delete %>">
                                        <i class="fas fa-trash-alt"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                        <% }); %>
                    <% } else { %>
                        <tr>
                            <td colspan="6" style="text-align:center; color:var(--muted); padding:60px 20px;">
                                <i class="fas fa-folder-open" style="font-size: 48px; color: rgba(255,255,255,0.1); margin-bottom: 16px; display: block;"></i>
                                <%= t.no_hotspot_user_data %>
                            </td>
                        </tr>
                    <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</main>

<script>
// Search Functionality
document.getElementById('userSearch').addEventListener('input', function(e) {
    const q = e.target.value.toLowerCase();
    const rows = document.querySelectorAll('#userTable tr');
    rows.forEach(r => {
        // Skip the "No data" row if it exists
        if(r.cells.length === 1) return;
        const text = r.textContent.toLowerCase();
        r.style.display = text.includes(q) ? '' : 'none';
    });
});

// User Detail Modal
function showUserInfo(name, profile, uptime, address) {
    Swal.fire({
        title: 'Detail Pengguna',
        html: `
            <div style="text-align: left; padding: 10px;">
                <div class="swal-form-group">
                    <span style="color: var(--muted); font-size: 12px;">Username</span>
                    <div style="font-size: 18px; font-weight: 700; color: white;">${name}</div>
                </div>
                <div class="swal-form-group">
                    <span style="color: var(--muted); font-size: 12px;">Profile</span>
                    <div style="font-size: 15px; color: #A78BFA;">${profile}</div>
                </div>
                <div class="swal-form-group">
                    <span style="color: var(--muted); font-size: 12px;">Uptime</span>
                    <div style="font-size: 15px; color: white;">${uptime || '-'}</div>
                </div>
                <div class="swal-form-group">
                    <span style="color: var(--muted); font-size: 12px;">IP Address</span>
                    <div style="font-size: 15px; font-family: monospace; color: #34D399;">${address || '-'}</div>
                </div>
            </div>
        `,
        customClass: { popup: 'glass-swal' },
        confirmButtonText: 'Tutup',
        confirmButtonColor: '#3b82f6'
    });
}

// Add User Modal
async function addUserModal() {
    const profiles = <%- JSON.stringify(profiles.map(p => p.name)) %>;
    let profileOptions = profiles.map(p => `<option value="${p}">${p}</option>`).join('');
    
    const { value: formValues } = await Swal.fire({
        title: '<%= t.add_hotspot_user %>',
        html: `
            <div class="swal-form-group">
                <label class="swal-label">Username</label>
                <input id="swal-user" class="swal2-input" style="width: 100%; margin: 0; max-width: 100%; box-sizing: border-box;" placeholder="Masukkan username">
            </div>
            <div class="swal-form-group">
                <label class="swal-label">Password</label>
                <input id="swal-pass" class="swal2-input" style="width: 100%; margin: 0; max-width: 100%; box-sizing: border-box;" placeholder="Masukkan password">
            </div>
            <div class="swal-form-group">
                <label class="swal-label">Profile Hotspot</label>
                <select id="swal-profile" class="swal2-select" style="width: 100%; margin: 0; max-width: 100%; box-sizing: border-box;">
                    ${profileOptions}
                </select>
            </div>
        `,
        focusConfirm: false,
        showCancelButton: true,
        confirmButtonText: 'Simpan',
        cancelButtonText: 'Batal',
        confirmButtonColor: '#10B981',
        cancelButtonColor: 'rgba(255,255,255,0.1)',
        customClass: { popup: 'glass-swal' },
        preConfirm: () => {
            const user = document.getElementById('swal-user').value;
            const pass = document.getElementById('swal-pass').value;
            if (!user || !pass) {
                Swal.showValidationMessage('Username dan Password wajib diisi');
                return false;
            }
            return {
                username: user,
                password: pass,
                profile: document.getElementById('swal-profile').value
            };
        }
    });

    if (formValues) {
        Swal.fire({ title: 'Menyimpan...', allowOutsideClick: false, customClass: { popup: 'glass-swal' }, didOpen: () => { Swal.showLoading(); }});
        try {
            const res = await fetch('/hotspot/api/user/add', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify(formValues)
            });
            const d = await res.json();
            if (d.success) {
                await Swal.fire({ icon: 'success', title: 'Berhasil', text: d.message, timer: 1500, showConfirmButton: false, customClass: { popup: 'glass-swal' } });
                location.reload();
            } else {
                throw new Error(d.message);
            }
        } catch (e) {
            Swal.fire({ icon: 'error', title: 'Gagal', text: e.message, customClass: { popup: 'glass-swal' } });
        }
    }
}

// Add Profile Modal
async function addProfileModal() {
    const { value: formValues } = await Swal.fire({
        title: '<%= t.add_hotspot_profile %>',
        html: `
            <div class="swal-form-group">
                <label class="swal-label"><%= t.profile_name %></label>
                <input id="swal-pname" class="swal2-input" style="width: 100%; margin: 0; max-width: 100%; box-sizing: border-box;" placeholder="cth: 2mbps">
            </div>
            <div class="swal-form-group">
                <label class="swal-label"><%= t.rate_limit %></label>
                <input id="swal-prate" class="swal2-input" style="width: 100%; margin: 0; max-width: 100%; box-sizing: border-box;" placeholder="cth: 1M/2M">
            </div>
            <div class="swal-form-group">
                <label class="swal-label"><%= t.shared_users %></label>
                <input id="swal-pshared" type="number" class="swal2-input" style="width: 100%; margin: 0; max-width: 100%; box-sizing: border-box;" value="1">
            </div>
        `,
        focusConfirm: false,
        showCancelButton: true,
        confirmButtonText: 'Simpan',
        cancelButtonText: 'Batal',
        confirmButtonColor: '#3b82f6',
        cancelButtonColor: 'rgba(255,255,255,0.1)',
        customClass: { popup: 'glass-swal' },
        preConfirm: () => {
            const name = document.getElementById('swal-pname').value;
            if (!name) {
                Swal.showValidationMessage('Nama profil wajib diisi');
                return false;
            }
            return {
                name: name,
                rateLimit: document.getElementById('swal-prate').value,
                sharedUsers: document.getElementById('swal-pshared').value
            };
        }
    });

    if (formValues) {
        Swal.fire({ title: 'Menyimpan...', allowOutsideClick: false, customClass: { popup: 'glass-swal' }, didOpen: () => { Swal.showLoading(); }});
        try {
            const res = await fetch('/hotspot/api/profile/add', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify(formValues)
            });
            const d = await res.json();
            if (d.success) {
                await Swal.fire({ icon: 'success', title: 'Berhasil', text: d.message, timer: 1500, showConfirmButton: false, customClass: { popup: 'glass-swal' } });
                location.reload();
            } else {
                throw new Error(d.message);
            }
        } catch (e) {
            Swal.fire({ icon: 'error', title: 'Gagal', text: e.message, customClass: { popup: 'glass-swal' } });
        }
    }
}

// Delete User
async function deleteUser(name) {
    const result = await Swal.fire({
        title: 'Hapus Pengguna?',
        text: `Anda yakin ingin menghapus pengguna hotspot "${name}"?`,
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#EF4444',
        cancelButtonColor: 'rgba(255,255,255,0.1)',
        confirmButtonText: 'Ya, Hapus',
        cancelButtonText: 'Batal',
        customClass: { popup: 'glass-swal' }
    });

    if (result.isConfirmed) {
        Swal.fire({ title: 'Menghapus...', allowOutsideClick: false, customClass: { popup: 'glass-swal' }, didOpen: () => { Swal.showLoading(); }});
        try {
            const res = await fetch('/hotspot/api/user/' + encodeURIComponent(name), { method: 'DELETE' });
            const d = await res.json();
            if (d.success) {
                await Swal.fire({ icon: 'success', title: 'Berhasil', text: d.message, timer: 1500, showConfirmButton: false, customClass: { popup: 'glass-swal' } });
                location.reload();
            } else {
                throw new Error(d.message);
            }
        } catch (e) {
            Swal.fire({ icon: 'error', title: 'Gagal', text: e.message, customClass: { popup: 'glass-swal' } });
        }
    }
}
</script>
</body>
</html>
