<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('partials/head') %>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        .stats-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(200px,1fr)); gap:16px; margin-bottom:24px; }
        .stat-card { background:var(--card-bg); border:1px solid var(--border); border-radius:16px; padding:22px; position:relative; overflow:hidden; transition:transform 0.25s, box-shadow 0.25s; }
        .stat-card:hover { transform:translateY(-4px); box-shadow:0 12px 24px rgba(0,0,0,0.1); background:var(--sidebar-bg); }
        .stat-card::before { content:''; position:absolute; top:0; left:0; right:0; height:3px; }
        .stat-card.blue::before { background:linear-gradient(90deg,#3B82F6,#6366F1); }
        .stat-card.green::before { background:linear-gradient(90deg,#10B981,#34D399); }
        .stat-card.red::before { background:linear-gradient(90deg,#EF4444,#F87171); }
        .stat-card.orange::before { background:linear-gradient(90deg,#F59E0B,#FCD34D); }
        .stat-card.purple::before { background:linear-gradient(90deg,#8B5CF6,#A78BFA); }
        .stat-label { font-size:13px; color:var(--muted); margin-bottom:8px; }
        .stat-value { font-size:30px; font-weight:700; line-height:1; }
        .stat-sub { font-size:12px; color:var(--muted); margin-top:8px; }
        .charts-grid { display:grid; grid-template-columns:1fr 1fr; gap:20px; margin-bottom:24px; }
        .card-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:18px; }
        .card-title { font-size:16px; font-weight:600; margin:0; }
        @media(max-width:1100px) { .charts-grid { grid-template-columns:1fr; } }
        @media(max-width:768px) { .stats-grid{grid-template-columns:repeat(2,1fr);} }
    </style>
    </style>
</head>
<body>
<%- include('partials/sidebar') %>
<main class="main">
    <%- include('partials/topbar', { title: 'Overview Dashboard' }) %>
    <div class="content">
        <h1 class="page-title"><%= t.welcome %>, <%= user.username %>! 👋</h1>

        <div class="stats-grid">
            <div class="stat-card blue">
                <div class="stat-label"><%= t.total_customers %></div>
                <div class="stat-value"><%= stats.totalCustomers || 0 %></div>
                <div class="stat-sub"><%= stats.activeCustomers || 0 %> <%= t.active %> · <%= stats.isolatedCustomers || 0 %> <%= t.isolated %></div>
            </div>
            <div class="stat-card green">
                <div class="stat-label"><%= t.monthly_revenue %></div>
                <div class="stat-value" style="font-size:22px;">Rp <%= Math.floor(stats.totalRevenue || 0).toLocaleString('id-ID') %></div>
                <div class="stat-sub"><%= t.paid_this_month %></div>
            </div>
            <div class="stat-card orange">
                <div class="stat-label"><%= t.unpaid_invoices %></div>
                <div class="stat-value"><%= stats.unpaidInvoices || 0 %></div>
                <div class="stat-sub"><%= stats.overdueInvoices || 0 %> <%= t.past_due %></div>
            </div>
            <div class="stat-card red">
                <div class="stat-label"><%= t.open_tickets %></div>
                <div class="stat-value"><%= stats.openTickets || 0 %></div>
                <div class="stat-sub"><%= t.needs_attention %></div>
            </div>
        </div>

        <% if (stats.overdueInvoices > 0) { %>
        <div style="background:rgba(239,68,68,.1); border:1px solid rgba(239,68,68,.3); color:var(--danger); padding:14px 18px; border-radius:12px; margin-bottom:20px; font-size:14px;">
            ⚠️ <strong><%= stats.overdueInvoices %></strong> <%= t.overdue_alert %> 
            <a href="/billing?status=unpaid" style="color:var(--primary); font-weight:600; margin-left:10px; text-decoration:none;"><%= t.view_invoice %> →</a>
        </div>
        <% } %>

        <div class="charts-grid">
            <div class="card">
                <div class="card-header"><h2 class="card-title">📈 <%= t.monthly_revenue %></h2></div>
                <canvas id="revenueChart" height="200"></canvas>
            </div>
            <div class="card">
                <div class="card-header"><h2 class="card-title">👥 <%= t.recent_customers %></h2></div>
                <canvas id="customerChart" height="200"></canvas>
            </div>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">
            <div class="card">
                <div class="card-header">
                    <h2 class="card-title">🧾 <%= t.recent_invoices %></h2>
                    <a href="/billing" class="btn btn-primary"><%= t.view_all %></a>
                </div>
                <table>
                    <thead><tr><th><%= t.customer %></th><th><%= t.amount %></th><th><%= t.status_label %></th></tr></thead>
                    <tbody>
                    <% if (recentInvoices && recentInvoices.length > 0) { %>
                        <% recentInvoices.slice(0,6).forEach(i => { %>
                        <tr>
                            <td><%= i.customer_name || '-' %></td>
                            <td>Rp <%= Math.floor(i.amount).toLocaleString('id-ID') %></td>
                            <td><span class="badge badge-<%= i.status %>"><%= i.status === 'paid' ? t.paid : t.unpaid %></span></td>
                        </tr>
                        <% }); %>
                    <% } else { %>
                        <tr><td colspan="3" style="text-align:center;color:var(--muted);padding:30px;"><%= t.no_invoices %></td></tr>
                    <% } %>
                    </tbody>
                </table>
            </div>
            <div class="card">
                <div class="card-header">
                    <h2 class="card-title">👤 <%= t.recent_customers %></h2>
                    <a href="/customers" class="btn btn-primary"><%= t.view_all %></a>
                </div>
                <table>
                    <thead><tr><th><%= t.full_name %></th><th><%= t.internet_packages %></th><th><%= t.status_label %></th></tr></thead>
                    <tbody>
                    <% if (recentCustomers && recentCustomers.length > 0) { %>
                        <% recentCustomers.forEach(c => { %>
                        <tr>
                            <td><%= c.name %></td>
                            <td style="font-size:12px;color:var(--muted)"><%= c.package_name || '-' %></td>
                            <td><span class="badge badge-<%= c.status %>"><%= c.status === 'active' ? t.active : t.isolated %></span></td>
                        </tr>
                        <% }); %>
                    <% } else { %>
                        <tr><td colspan="3" style="text-align:center;color:var(--muted);padding:30px;"><%= t.no_customers %></td></tr>
                    <% } %>
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card" style="margin-top:20px;">
            <div class="card-header">
                <h2 class="card-title">🚀 <%= t.network_traffic %></h2>
                <div style="display:flex; align-items:center; gap:15px;">
                    <select id="interfaceSelector" style="background:var(--card-bg); color:var(--text); border:1px solid var(--border); border-radius:6px; padding:4px 8px; font-size:12px; cursor:pointer; outline:none;">
                        <option value="ether1">ether1</option>
                        <option value="ether2">ether2</option>
                        <option value="ether3">ether3</option>
                        <option value="ether4">ether4</option>
                        <option value="ether5">ether5</option>
                        <option value="sfp-sfpplus1">sfp-sfpplus1</option>
                        <option value="combo1">combo1</option>
                        <option value="bridge">bridge</option>
                    </select>
                    <div style="display:flex; gap:15px; font-size:12px;">
                        <span style="color:#10B981; font-weight:600;"><i class="fas fa-arrow-down"></i> <%= t.download %>: <span id="totalRx">0 Mbps</span></span>
                        <span style="color:#3B82F6; font-weight:600;"><i class="fas fa-arrow-up"></i> <%= t.upload %>: <span id="totalTx">0 Mbps</span></span>
                    </div>
                </div>
            </div>
            <canvas id="trafficChart" height="100"></canvas>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-top:20px;">
            <div class="card">
                <div class="card-header">
                    <h2 class="card-title">📡 <%= t.olt_management %></h2>
                    <a href="/olt" class="btn btn-primary"><%= t.detail_olt %></a>
                </div>
                <div style="padding:10px 0;">
                    <div style="display:flex;justify-content:space-between;margin-bottom:10px;">
                        <span style="color:var(--muted)"><%= t.onu_online_status %></span>
                        <span style="font-weight:600"><%= oltStats.online %> / <%= oltStats.total %></span>
                    </div>
                    <div style="height:8px;background:var(--sub-bg);border-radius:4px;overflow:hidden">
                        <div style="height:100%;width:<%= (oltStats.total > 0 ? (oltStats.online/oltStats.total)*100 : 0) %>%;background:var(--success)"></div>
                    </div>
                </div>
            </div>
            <div class="card">
                <div class="card-header">
                    <h2 class="card-title">🔌 <%= t.router_management %></h2>
                    <a href="/mikrotik" class="btn btn-primary"><%= t.manage_router %></a>
                </div>
                <div style="padding:10px 0;">
                    <div style="display:flex;justify-content:space-between;margin-bottom:10px;">
                        <span style="color:var(--muted)"><%= t.active_router %></span>
                        <span style="font-weight:600"><%= routerStats.online %> / <%= routerStats.total %></span>
                    </div>
                    <div style="height:8px;background:var(--sub-bg);border-radius:4px;overflow:hidden">
                        <div style="height:100%;width:<%= (routerStats.total > 0 ? (routerStats.online/routerStats.total)*100 : 0) %>%;background:var(--primary)"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

<script>
const isLight = document.documentElement.classList.contains('light-theme');
const gridColor = isLight ? 'rgba(0,0,0,0.05)' : 'rgba(255,255,255,0.06)';
const tickColor = isLight ? '#64748B' : '#94A3B8';
const monthlyRevenue = <%- JSON.stringify(monthlyRevenue) %>;
const monthlyCustomers = <%- JSON.stringify(monthlyCustomers) %>;

new Chart(document.getElementById('revenueChart'), {
    type: 'line',
    data: {
        labels: monthlyRevenue.map(d => d.month),
        datasets: [{ label: '<%= t.revenue %>', data: monthlyRevenue.map(d => d.revenue),
            borderColor: '#3B82F6', backgroundColor: 'rgba(59,130,246,0.1)', fill: true, tension: 0.4, pointRadius: 4 }]
    },
    options: { responsive: true, plugins: { legend: { display: false } },
        scales: { y: { beginAtZero: true, grid: { color: gridColor }, ticks: { color: tickColor, callback: v => 'Rp ' + (v/1000).toFixed(0) + 'K' } },
                  x: { grid: { color: gridColor }, ticks: { color: tickColor } } } }
});

new Chart(document.getElementById('customerChart'), {
    type: 'bar',
    data: {
        labels: monthlyCustomers.map(d => d.month),
        datasets: [{ label: '<%= t.new_customers %>', data: monthlyCustomers.map(d => d.count),
            backgroundColor: 'rgba(139,92,246,0.5)', borderColor: '#8B5CF6', borderWidth: 2, borderRadius: 6 }]
    },
    options: { responsive: true, plugins: { legend: { display: false } },
        scales: { y: { beginAtZero: true, grid: { color: gridColor }, ticks: { color: tickColor, stepSize: 1 } },
                  x: { grid: { color: gridColor }, ticks: { color: tickColor } } } }
});

// Traffic Monitor Logic
const trafficCtx = document.getElementById('trafficChart').getContext('2d');
const trafficChart = new Chart(trafficCtx, {
    type: 'line',
    data: {
        labels: Array(30).fill(''),
        datasets: [
            { label: 'Download (Mbps)', data: Array(30).fill(0), borderColor: '#10B981', backgroundColor: 'rgba(16,185,129,0.1)', fill: true, tension: 0.4, pointRadius: 0, borderWidth: 2 },
            { label: 'Upload (Mbps)', data: Array(30).fill(0), borderColor: '#3B82F6', backgroundColor: 'rgba(59,130,246,0.1)', fill: true, tension: 0.4, pointRadius: 0, borderWidth: 2 }
        ]
    },
    options: {
        responsive: true,
        animation: { duration: 800 },
        plugins: { legend: { display: false } },
        scales: {
            y: { beginAtZero: true, grid: { color: gridColor }, ticks: { color: tickColor, callback: v => v + ' M' } },
            x: { display: false }
        }
    }
});

async function updateTraffic() {
    try {
        const iface = document.getElementById('interfaceSelector').value;
        const res = await fetch(`/api/mikrotik/traffic?interface=${iface}`);
        const d = await res.json();
        if (d.success && d.data.length > 0) {
            let totalRx = 0; let totalTx = 0;
            d.data.forEach(r => { totalRx += r.rx; totalTx += r.tx; });
            
            const rxMbps = (totalRx / 1000000).toFixed(2);
            const txMbps = (totalTx / 1000000).toFixed(2);
            
            document.getElementById('totalRx').textContent = rxMbps + ' Mbps';
            document.getElementById('totalTx').textContent = txMbps + ' Mbps';

            // Update Chart
            trafficChart.data.datasets[0].data.shift();
            trafficChart.data.datasets[0].data.push(rxMbps);
            trafficChart.data.datasets[1].data.shift();
            trafficChart.data.datasets[1].data.push(txMbps);
            trafficChart.update('none');
        }
    } catch (e) {}
}

document.getElementById('interfaceSelector').addEventListener('change', () => {
    trafficChart.data.datasets[0].data = Array(30).fill(0);
    trafficChart.data.datasets[1].data = Array(30).fill(0);
    trafficChart.update();
    updateTraffic();
});

setInterval(updateTraffic, 2000);
updateTraffic();
</script>
</body>
</html>
