<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dino-Bill | Portal Teknisi</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap');
        :root{--primary:#3B82F6;--secondary:#8B5CF6;--bg:#0B0F19;--sidebar:#111827;--card:rgba(30,41,59,.5);--border:rgba(255,255,255,.05);--text:#F8FAFC;--muted:#94A3B8;--success:#10B981;--danger:#EF4444;--warning:#F59E0B;}
        *{box-sizing:border-box;}body{margin:0;font-family:'Outfit',sans-serif;background:var(--bg);color:var(--text);display:flex;min-height:100vh;}
        .sidebar{width:260px;background:var(--sidebar);border-right:1px solid var(--border);position:fixed;height:100vh;display:flex;flex-direction:column;z-index:100;}
        .sidebar-brand{padding:24px;font-size:22px;font-weight:700;background:linear-gradient(135deg,#60A5FA,#A78BFA);-webkit-background-clip:text;-webkit-text-fill-color:transparent;border-bottom:1px solid var(--border);}
        .nav-menu{padding:16px 0;flex:1;overflow-y:auto;}
        .nav-item{display:flex;align-items:center;padding:12px 20px;color:var(--muted);text-decoration:none;font-weight:500;gap:12px;font-size:14px;border-left:3px solid transparent;transition:all .25s;}
        .nav-item:hover,.nav-item.active{color:var(--text);background:rgba(255,255,255,.04);border-left-color:var(--primary);}
        .main{flex:1;margin-left:260px;display:flex;flex-direction:column;}
        .topbar{height:65px;background:rgba(17,24,39,.9);backdrop-filter:blur(12px);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;padding:0 28px;position:sticky;top:0;z-index:90;}
        .content{padding:28px;}.page-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:22px;}.page-title{font-size:24px;font-weight:700;margin:0;}
        .card{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:24px;margin-bottom:20px;}
        .ticket-list{display:grid;gap:16px;}
        .ticket-card{background:rgba(255,255,255,.02);border:1px solid var(--border);border-radius:12px;padding:16px;display:flex;justify-content:space-between;align-items:center;}
        .ticket-info h4{margin:0 0 5px;font-size:16px;}
        .ticket-info p{margin:0;font-size:13px;color:var(--muted);}
        .badge{padding:4px 10px;border-radius:20px;font-size:11px;font-weight:600;}
        .badge-open{background:rgba(239,68,68,.1);color:var(--danger);}
        .btn{padding:8px 14px;border-radius:8px;border:none;cursor:pointer;font-weight:500;font-size:13px;}
        .btn-success{background:var(--success);color:white;}
    </style>
</head>
<body>
<%- include('partials/sidebar') %>
<main class="main">
    <%- include('partials/topbar', { title: 'Portal Teknisi' }) %>
    <div class="content">
        <div class="page-header"><h1 class="page-title">Tugas Teknisi</h1></div>
        <div class="card">
            <h3 style="margin:0 0 20px;font-size:16px">Trouble Tickets Terbuka (<%= tickets.length %>)</h3>
            <div class="ticket-list">
                <% if(tickets.length > 0) { %>
                    <% tickets.forEach(t => { %>
                    <div class="ticket-card" id="ticket-<%= t.id %>">
                        <div class="ticket-info">
                            <h4><%= t.title %></h4>
                            <p>Pelanggan: <strong><%= t.customer_name || 'Umum' %></strong> | Prioritas: <span style="color:<%= t.priority === 'high' ? 'var(--danger)' : 'var(--primary)' %>"><%= t.priority === 'high' ? '🔴 Tinggi' : '🔵 Normal' %></span></p>
                            <% if(t.description) { %><p style="font-size:12px;margin-top:4px;color:var(--muted)"><%= t.description.substring(0, 120) %><%= t.description.length > 120 ? '...' : '' %></p><% } %>
                            <p style="font-size:11px;margin-top:4px;color:var(--muted)">Dibuat: <%= new Date(t.created_at).toLocaleDateString('id-ID', {day:'2-digit',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'}) %></p>
                        </div>
                        <div style="display:flex;align-items:center;gap:10px">
                            <span class="badge badge-open">OPEN</span>
                            <button class="btn btn-success" onclick="closeTicket(<%= t.id %>)">✓ Selesaikan</button>
                        </div>
                    </div>
                    <% }); %>
                <% } else { %>
                    <p style="text-align:center;color:var(--muted);padding:40px">🎉 Tidak ada tugas terbuka. Semua beres!</p>
                <% } %>
            </div>
        </div>
    </div>
</main>
<div class="toast" id="toast" style="position:fixed;bottom:24px;right:24px;background:#111827;border:1px solid var(--border);border-radius:12px;padding:14px 20px;z-index:9999;display:none;font-size:14px;"></div>
<script>
async function closeTicket(id) {
    if (!confirm('Tandai tiket ini sebagai selesai?')) return;
    try {
        const res = await fetch(`/tickets/api/${id}/close`, { method: 'POST' });
        const d = await res.json();
        showToast(d.message, d.success ? 'success' : 'error');
        if (d.success) {
            const el = document.getElementById('ticket-' + id);
            if (el) el.style.display = 'none';
            setTimeout(() => location.reload(), 1500);
        }
    } catch(e) {
        showToast('Gagal: ' + e.message, 'error');
    }
}
function showToast(msg,type){const t=document.getElementById('toast');t.textContent=msg;t.style.borderColor=type==='success'?'rgba(16,185,129,.4)':'rgba(239,68,68,.4)';t.style.color=type==='success'?'#10B981':'#EF4444';t.style.display='block';setTimeout(()=>t.style.display='none',3500);}
</script>
</body>
</html>
