<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dino-Bill | Peta Pelanggan</title>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap');
        :root{--primary:#3B82F6;--secondary:#8B5CF6;--bg:#0B0F19;--sidebar:#111827;--card:rgba(30,41,59,.5);--border:rgba(255,255,255,.05);--text:#F8FAFC;--muted:#94A3B8;--success:#10B981;--danger:#EF4444;--warning:#F59E0B;}
        *{box-sizing:border-box;}body{margin:0;font-family:'Outfit',sans-serif;background:var(--bg);color:var(--text);display:flex;min-height:100vh;}
        .sidebar{width:260px;background:var(--sidebar);border-right:1px solid var(--border);position:fixed;height:100vh;display:flex;flex-direction:column;z-index:1000;}
        .sidebar-brand{padding:24px;font-size:22px;font-weight:700;background:linear-gradient(135deg,#60A5FA,#A78BFA);-webkit-background-clip:text;-webkit-text-fill-color:transparent;border-bottom:1px solid var(--border);}
        .nav-menu{padding:16px 0;flex:1;overflow-y:auto;}
        .nav-item{display:flex;align-items:center;padding:12px 20px;color:var(--muted);text-decoration:none;font-weight:500;gap:12px;font-size:14px;border-left:3px solid transparent;transition:all .25s;}
        .nav-item:hover,.nav-item.active{color:var(--text);background:rgba(255,255,255,.04);border-left-color:var(--primary);}
        .main{flex:1;margin-left:260px;display:flex;flex-direction:column;height:100vh;}
        #map{flex:1;width:100%;z-index:10;}
        .topbar{height:65px;background:rgba(17,24,39,.9);backdrop-filter:blur(12px);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;padding:0 28px;z-index:100;}
        .map-overlay{position:absolute;top:80px;right:20px;z-index:100;background:rgba(15,23,42,.9);padding:15px;border-radius:12px;border:1px solid var(--border);width:250px;}
        .map-overlay h3{margin:0 0 10px;font-size:14px;}
        .legend-item{display:flex;align-items:center;gap:8px;font-size:12px;margin-bottom:5px;}
        .dot{width:10px;height:10px;border-radius:50%;}
    </style>
</head>
<body>
<%- include('partials/sidebar') %>
<main class="main">
    <%- include('partials/topbar', { title: 'Sebaran Lokasi Pelanggan' }) %>
    <div id="map"></div>
    <div class="map-overlay">
        <h3>Legend</h3>
        <div class="legend-item"><div class="dot" style="background:var(--success)"></div> Aktif</div>
        <div class="legend-item"><div class="dot" style="background:var(--danger)"></div> Terisolir</div>
        <hr style="border-color:var(--border);margin:10px 0;">
        <p style="font-size:11px;color:var(--muted);margin:0">Total Pelanggan Terpetakan: <b id="mapCount">0</b></p>
    </div>
</main>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
    const map = L.map('map').setView([-6.200000, 106.816666], 13);
    L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; <a href="https://carto.com/attributions">CARTO</a>'
    }).addTo(map);

    const customers = <%- JSON.stringify(customers) %>;
    let count = 0;
    
    customers.forEach(c => {
        if(c.lat && c.lng) {
            const marker = L.circleMarker([c.lat, c.lng], {
                radius: 8,
                fillColor: c.status === 'active' ? '#10B981' : '#EF4444',
                color: "#fff",
                weight: 2,
                opacity: 1,
                fillOpacity: 0.8
            }).addTo(map);
            
            marker.bindPopup(`
                <div style="color:#000">
                    <b style="font-size:14px">${c.name}</b><br>
                    <span style="font-size:12px">${c.address || '-'}</span><br>
                    <span style="font-size:12px;color:${c.status === 'active' ? 'green' : 'red'}">${c.status.toUpperCase()}</span>
                </div>
            `);
            count++;
        }
    });

    document.getElementById('mapCount').innerText = count;
    if(count > 0) {
        const group = new L.featureGroup(customers.filter(c => c.lat && c.lng).map(c => L.marker([c.lat, c.lng])));
        map.fitBounds(group.getBounds().pad(0.1));
    }
</script>
</body>
</html>
