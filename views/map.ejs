<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('partials/head') %>
    <title><%= t.map_title_tag %></title>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet.draw/1.0.4/leaflet.draw.css" />
    <style>
        #map { flex:1; width:100%; z-index:10; cursor: crosshair; }
        
        /* Glassmorphism Panels */
        .glass-panel {
            background: rgba(30, 41, 59, 0.7);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.3);
            border-radius: 16px;
        }

        .map-tools { 
            position: absolute; top: 90px; left: 20px; z-index: 1000; 
            display: flex; flex-direction: column; gap: 12px;
        }
        
        .tool-btn {
            background: rgba(30, 41, 59, 0.8); border: 1px solid rgba(255, 255, 255, 0.1);
            color: var(--text); padding: 12px 18px; border-radius: 12px;
            cursor: pointer; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            backdrop-filter: blur(10px); display: flex; align-items: center; gap: 12px; 
            font-weight: 500; font-size: 14px; box-shadow: 0 4px 15px rgba(0,0,0,0.2);
        }
        .tool-btn i { font-size: 16px; width: 20px; text-align: center; }
        .tool-btn:hover { background: var(--primary); color: white; transform: translateX(5px); border-color: var(--primary); }
        .tool-btn.active { background: var(--primary); color: white; border-color: var(--primary); box-shadow: 0 0 15px rgba(59, 130, 246, 0.5); }
        
        .map-overlay { 
            position:absolute; top:150px; right:20px; z-index:1000; 
            padding:20px; width:280px;
        }
        
        .legend-item { display:flex; align-items:center; gap:12px; font-size:13px; margin-bottom:12px; color: var(--text); }
        .icon-box { 
            width:28px; height:28px; display:flex; align-items:center; 
            justify-content:center; border-radius:8px; font-size: 13px;
        }

        /* Marker Styles */
        .marker-server { color: #8B5CF6; font-size: 22px; filter: drop-shadow(0 0 8px rgba(139, 92, 246, 0.6)); }
        .marker-odp { color: #F59E0B; font-size: 20px; filter: drop-shadow(0 0 8px rgba(245, 158, 11, 0.6)); }
        .marker-cust { color: #10B981; }

        @media(max-width:768px) { 
            .map-tools { left: 15px; top: 160px; }
            .map-overlay { top:auto; bottom:20px; right:10px; left:10px; width:auto; display:none; } 
            .map-search { right: 15px; top: 85px; }
            .search-results { width: calc(100vw - 30px); right: 0; }
            .search-input-wrapper.expanded { width: calc(100vw - 30px); }
        }

        /* Custom Popup */
        .leaflet-popup-content-wrapper { background: rgba(30, 41, 59, 0.95); backdrop-filter: blur(10px); color: var(--text); border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
        .leaflet-popup-tip { background: rgba(30, 41, 59, 0.95); }
        .popup-title { font-weight: 700; font-size: 15px; margin-bottom: 6px; display: block; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 6px; }
        .popup-desc { font-size: 13px; color: var(--muted); }
        .btn-delete { color: #ef4444; background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.2); border-radius: 6px; cursor: pointer; font-size: 12px; margin-top: 10px; padding: 6px 12px; transition: 0.2s; width: 100%; }
        .btn-delete:hover { background: #ef4444; color: white; }

        /* Search Box */
        .map-search {
            position: absolute; top: 90px; right: 20px;
            z-index: 1010; display: flex; flex-direction: column; align-items: flex-end;
        }
        .search-input-wrapper {
            display: flex; align-items: center; background: rgba(30, 41, 59, 0.8);
            backdrop-filter: blur(12px); border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 25px; padding: 0; width: 50px; height: 50px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.3);
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            cursor: pointer; overflow: hidden;
        }
        .search-input-wrapper.expanded {
            width: 450px; border-radius: 16px; padding: 0 20px; cursor: default;
        }
        .search-input-wrapper:focus-within { border-color: var(--primary); box-shadow: 0 8px 32px rgba(59, 130, 246, 0.2); }
        .search-input-wrapper i.fa-search { 
            color: var(--muted); font-size: 18px; width: 50px; height: 50px; 
            display: flex; align-items: center; justify-content: center; flex-shrink: 0;
            transition: color 0.3s;
        }
        .search-input-wrapper.expanded i.fa-search {
            width: auto; height: auto; margin-right: 15px; color: var(--primary);
        }
        .search-input {
            flex: 1; border: none; background: transparent; 
            color: var(--text); outline: none; font-size: 15px; font-family: inherit;
            opacity: 0; padding: 0; transition: opacity 0.2s; pointer-events: none;
        }
        .search-input-wrapper.expanded .search-input {
            opacity: 1; padding: 16px 0; pointer-events: auto;
        }
        #closeSearchIcon {
            display: none; cursor: pointer; color: var(--muted); font-size: 16px; transition: color 0.2s;
        }
        .search-input-wrapper.expanded #closeSearchIcon {
            display: flex; width: auto; height: auto; margin-left: 10px; padding: 5px;
        }
        .search-input-wrapper.expanded #closeSearchIcon:hover { color: #ef4444; }
        
        .search-results {
            position: absolute; top: 60px; right: 0; width: 450px; background: rgba(30, 41, 59, 0.95);
            backdrop-filter: blur(12px); border: 1px solid rgba(255, 255, 255, 0.1); 
            border-radius: 12px; max-height: 300px; overflow-y: auto; display: none; 
            box-shadow: 0 10px 25px rgba(0,0,0,0.4);
        }
        .search-item {
            padding: 14px 20px; cursor: pointer; border-bottom: 1px solid rgba(255,255,255,0.05);
            display: flex; justify-content: space-between; align-items: center; transition: background 0.2s;
        }
        .search-item:last-child { border-bottom: none; }
        .search-item:hover { background: rgba(255,255,255,0.1); }

        /* Layer Toggle */
        .layer-toggle {
            display: flex; align-items: center; justify-content: space-between;
            margin-bottom: 12px; font-size: 14px; cursor: pointer; padding: 8px 12px;
            border-radius: 8px; transition: background 0.2s;
        }
        .layer-toggle:hover { background: rgba(255,255,255,0.05); }
        .toggle-switch {
            width: 38px; height: 20px; background: rgba(255,255,255,0.1); border-radius: 10px;
            position: relative; transition: .3s;
        }
        .toggle-switch::after {
            content: ''; position: absolute; width: 16px; height: 16px;
            background: #cbd5e1; border-radius: 50%; top: 2px; left: 2px; transition: .3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .active .toggle-switch { background: var(--primary); }
        .active .toggle-switch::after { left: 20px; background: white; }

        /* Cable Color Picker */
        .cable-color-picker {
            margin: 5px 0; padding: 15px; border-radius: 12px; 
            border: 1px solid rgba(255,255,255,0.05); background: rgba(0,0,0,0.2);
        }
        .color-opt {
            width: 24px; height: 24px; border-radius: 50%; cursor: pointer;
            transition: transform 0.2s, box-shadow 0.2s; border: 2px solid transparent;
        }
        .color-opt:hover { transform: scale(1.1); }
        .color-opt.active { border-color: white; transform: scale(1.1); box-shadow: 0 0 10px currentColor; }

        /* Flowing Cable Animation */
        @keyframes flow {
            from { stroke-dashoffset: 20; }
            to { stroke-dashoffset: 0; }
        }
        .flow-line {
            animation: flow 1s linear infinite;
        }
    </style>
</head>
<body>
<%- include('partials/sidebar') %>
<main class="main" style="position: relative;">
    <%- include('partials/topbar', { title: t.network_map_title }) %>
    
    <div id="map"></div>

    <div class="map-search" id="mapSearchContainer">
        <div class="search-input-wrapper" id="searchWrapper" onclick="expandSearch()">
            <i class="fas fa-search"></i>
            <input type="text" id="searchInput" class="search-input" placeholder="<%= t.search_customer_odp %>" onkeyup="searchMap()">
            <i class="fas fa-times" id="closeSearchIcon" onclick="collapseSearch(event)"></i>
        </div>
        <div id="searchResults" class="search-results"></div>
    </div>

    <div class="map-tools">
        <button class="tool-btn" onclick="setMode('server')" id="btn-server">
            <i class="fas fa-server"></i> <span><%= t.add_server %></span>
        </button>
        <button class="tool-btn" onclick="setMode('odp')" id="btn-odp">
            <i class="fas fa-share-nodes"></i> <span><%= t.add_odp %></span>
        </button>
        
        <div class="cable-color-picker">
            <label style="font-size: 12px; color: var(--muted); display: block; margin-bottom: 8px; font-weight: 500"><i class="fas fa-palette"></i> <%= t.cable_color %>:</label>
            <div style="display: flex; gap: 8px">
                <div class="color-opt active" onclick="setCableColor('#3b82f6', this)" style="background: #3b82f6; color: #3b82f6"></div>
                <div class="color-opt" onclick="setCableColor('#ef4444', this)" style="background: #ef4444; color: #ef4444"></div>
                <div class="color-opt" onclick="setCableColor('#f59e0b', this)" style="background: #f59e0b; color: #f59e0b"></div>
                <div class="color-opt" onclick="setCableColor('#10b981', this)" style="background: #10b981; color: #10b981"></div>
                <div class="color-opt" onclick="setCableColor('#8b5cf6', this)" style="background: #8b5cf6; color: #8b5cf6"></div>
            </div>
        </div>

        <button class="tool-btn" onclick="startDrawCable()" id="btn-cable">
            <i class="fas fa-project-diagram"></i> <span><%= t.draw_cable %></span>
        </button>
        
        <button class="tool-btn" onclick="setMode('connect')" id="btn-connect">
            <i class="fas fa-link"></i> <span><%= t.connect_devices %></span>
        </button>

        <button class="tool-btn" onclick="resetMode()" style="margin-top:10px; opacity:0.7">
            <i class="fas fa-mouse-pointer"></i> <span><%= t.explore_mode %></span>
        </button>
        <button class="tool-btn" onclick="locateUser()" style="opacity:0.7">
            <i class="fas fa-location-arrow"></i> <span><%= t.my_location %></span>
        </button>
    </div>

    <div class="map-overlay glass-panel">
        <h3 style="font-size:16px; margin-bottom:18px; color: var(--text); display: flex; align-items: center; gap: 8px;"><i class="fas fa-layer-group"></i> <%= t.layer_legend %></h3>
        
        <div class="layer-toggle active" onclick="toggleLayer('customers', this)">
            <span><%= t.customers %></span>
            <div class="toggle-switch"></div>
        </div>
        <div class="layer-toggle active" onclick="toggleLayer('objects', this)">
            <span><%= t.server_odp %></span>
            <div class="toggle-switch"></div>
        </div>
        <div class="layer-toggle active" onclick="toggleLayer('cables', this)">
            <span><%= t.main_cable_path %></span>
            <div class="toggle-switch"></div>
        </div>
        <div class="layer-toggle active" onclick="toggleLayer('dropCables', this)">
            <span><%= t.last_mile_cable %></span>
            <div class="toggle-switch"></div>
        </div>

        <hr style="border:none; border-top:1px solid var(--border); margin:15px 0">

        <div class="legend-item"><div class="icon-box" style="background:rgba(139,92,246,0.2); color:#8B5CF6"><i class="fas fa-server"></i></div> <%= t.server_main %></div>
        <div class="legend-item"><div class="icon-box" style="background:rgba(245,158,11,0.2); color:#F59E0B"><i class="fas fa-share-nodes"></i></div> <%= t.odp_splitter %></div>
        <div class="legend-item"><div class="icon-box" style="background:rgba(16,185,129,0.2); color:#10B981"><i class="fas fa-user"></i></div> <%= t.active_customer %></div>
        <div class="legend-item"><div class="icon-box" style="background:rgba(239,68,68,0.2); color:#EF4444"><i class="fas fa-user"></i></div> <%= t.isolated_customer %></div>
        
        <p style="font-size:11px; color:var(--muted); margin-top:15px">
            <i class="fas fa-info-circle"></i> <%= t.toolbox_info %>
        </p>
    </div>
</main>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet.draw/1.0.4/leaflet.draw.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    const customers = <%- JSON.stringify(customers) %>;
    const initialObjects = <%- JSON.stringify(objects) %>;
    const initialCables = <%- JSON.stringify(cables) %>;
    const t = <%- JSON.stringify(t) %>;

    // Initialize Map without default zoom control to avoid overlaps
    const map = L.map('map', { zoomControl: false }).setView([-6.200000, 106.816666], 13);
    
    // Add Zoom Control to Bottom Right
    L.control.zoom({ position: 'bottomright' }).addTo(map);
    
    // Premium Dark Map
    L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
        attribution: '&copy; OpenStreetMap contributors'
    }).addTo(map);

    // Feature Groups
    const customerGroup = L.layerGroup().addTo(map);
    const objectGroup = L.layerGroup().addTo(map);
    const cableGroup = L.layerGroup().addTo(map);
    const dropCableGroup = L.layerGroup().addTo(map);
    const drawControlGroup = new L.FeatureGroup().addTo(map);

    let selectedCableColor = '#3b82f6';
    let connectSource = null;
    let currentMode = null;

    // Icons
    const serverIcon = L.divIcon({
        html: '<div style="color:#8B5CF6; font-size:20px"><i class="fas fa-server"></i></div>',
        className: 'custom-div-icon', iconSize: [24, 24], iconAnchor: [12, 12]
    });
    const odpIcon = L.divIcon({
        html: '<div style="color:#F59E0B; font-size:18px"><i class="fas fa-share-nodes"></i></div>',
        className: 'custom-div-icon', iconSize: [20, 20], iconAnchor: [10, 10]
    });

    function setCableColor(color, el) {
        selectedCableColor = color;
        document.querySelectorAll('.color-opt').forEach(opt => {
            opt.style.border = 'none';
            opt.classList.remove('active');
        });
        el.style.border = '2px solid white';
        el.classList.add('active');
        
        // Update polyline drawer options
        polylineDrawer.options.shapeOptions.color = color;
    }

    // Render Data
    function renderMarkers() {
        customerGroup.clearLayers();
        dropCableGroup.clearLayers();
        
        customers.forEach(c => {
            if(c.lat && c.lng) {
                // Add Marker
                const marker = L.circleMarker([c.lat, c.lng], {
                    radius: 7,
                    fillColor: c.status === 'active' ? '#10B981' : '#EF4444',
                    color: "#fff", weight: 1.5, opacity: 1, fillOpacity: 0.9,
                    customerData: c
                }).addTo(customerGroup);
                
                let redamanHtml = '';
                if (c.redaman !== 'N/A') {
                    const power = parseFloat(c.redaman);
                    const isBad = power < -26 || power > -8; // threshold untuk redaman jelek
                    redamanHtml = `<i class="fas fa-signal" style="color: ${isBad ? '#EF4444' : '#10B981'}; width:14px"></i> <span style="font-size:12px" id="rx-map-${c.id}">Redaman: <b>${c.redaman} dBm</b> (${c.onu_status})</span><br>`;
                } else {
                    redamanHtml = `<i class="fas fa-signal" style="color: var(--muted); width:14px"></i> <span style="font-size:12px; color:var(--muted)" id="rx-map-${c.id}">Redaman: N/A</span><br>`;
                }
                
                marker.bindPopup(`
                    <span class="popup-title" style="margin-bottom:2px">${c.name}</span>
                    <span class="popup-desc" style="display:block; margin-bottom:8px">${c.address || '-'}</span>
                    
                    <div style="background: rgba(0,0,0,0.2); padding: 8px 10px; border-radius: 8px; margin-bottom: 8px; line-height: 1.6; border: 1px solid rgba(255,255,255,0.05);">
                        ${redamanHtml}
                        <i class="fas fa-box" style="color:var(--muted); width:14px"></i> <span style="font-size:12px">Paket: ${c.package_name || '-'}</span><br>
                        <i class="fas fa-user-circle" style="color:var(--muted); width:14px"></i> <span style="font-size:12px">PPPoE: ${c.pppoe_username || '-'}</span><br>
                        <i class="fas fa-phone" style="color:var(--muted); width:14px"></i> <span style="font-size:12px">WA: ${c.phone ? '<a href="https://wa.me/'+c.phone.replace(/\D/g, '')+'" target="_blank" style="color:#3B82F6; text-decoration:none;">'+c.phone+'</a>' : '-'}</span>
                    </div>
                    
                    <span class="badge ${c.status === 'active' ? 'badge-active' : 'badge-danger'}" style="display:inline-block">${c.status.toUpperCase()}</span>
                `, { minWidth: 200 });

                // Add Drop Cable (ODP to Customer)
                if(c.odp_lat && c.odp_lng) {
                    const dist = map.distance([c.odp_lat, c.odp_lng], [c.lat, c.lng]);
                    const poly = L.polyline([[c.odp_lat, c.odp_lng], [c.lat, c.lng]], {
                        color: c.status === 'active' ? '#10B981' : '#EF4444',
                        weight: 2,
                        dashArray: '10, 10',
                        opacity: 0.6,
                        className: c.status === 'active' ? 'flow-line' : '' // Only animate if active
                    }).addTo(dropCableGroup);
                    
                    poly.bindPopup(`
                        <span class="popup-title">Estimasi Drop Core</span>
                        <span class="popup-desc">Dari: ${c.odp_name || 'ODP'}<br>Ke: ${c.name}</span><br>
                        <span style="color:var(--primary); font-weight:600; font-size:12px">Jarak: ${dist.toFixed(1)} meter</span>
                    `);
                }
            }
        });

        objectGroup.clearLayers();
        initialObjects.forEach(obj => {
            const icon = obj.type === 'server' ? serverIcon : odpIcon;
            const marker = L.marker([obj.lat, obj.lng], { icon: icon, draggable: true }).addTo(objectGroup);
            
            // Add custom property for easier access
            marker.objData = obj;
            
            marker.bindPopup(`
                <div style="min-width:140px">
                    <span class="popup-title">${obj.name}</span>
                    <span class="popup-desc">Tipe: ${obj.type.toUpperCase()}</span><br>
                    <div style="display:flex; gap:8px; margin-top:8px">
                        <button class="btn" style="flex:1; background:rgba(59,130,246,0.1); color:#3B82F6; border:1px solid rgba(59,130,246,0.2); font-size:12px; padding:6px; border-radius:6px; cursor:pointer;" onclick="editObject(${obj.id})"><i class="fas fa-edit"></i> Edit</button>
                        <button class="btn-delete" style="flex:1; margin-top:0;" onclick="deleteObject(${obj.id})"><i class="fas fa-trash"></i> Hapus</button>
                    </div>
                    <div style="font-size:10px; color:var(--muted); margin-top:10px; text-align:center; line-height:1.4;">
                        💡 <i>Geser (drag) ikon untuk memindah koordinat secara instan</i>
                    </div>
                </div>
            `);

            marker.on('click', (e) => {
                if (currentMode === 'connect') {
                    handleConnectMode(marker);
                }
            });

            marker.on('dragend', async function(e) {
                const position = marker.getLatLng();
                const confirm = await Swal.fire({
                    title: 'Update Koordinat?',
                    text: `Pindahkan ${obj.name} ke koordinat baru?`,
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonText: 'Ya, Simpan',
                    cancelButtonText: 'Batal'
                });
                if (confirm.isConfirmed) {
                    try {
                        const res = await fetch(`/map/api/objects/${obj.id}`, {
                            method: 'PUT',
                            headers: {'Content-Type': 'application/json'},
                            body: JSON.stringify({ name: obj.name, lat: position.lat, lng: position.lng })
                        });
                        const d = await res.json();
                        if (d.success) {
                            Swal.fire({title: 'Tersimpan!', icon: 'success', toast: true, position: 'top-end', timer: 2000, showConfirmButton: false});
                            obj.lat = position.lat;
                            obj.lng = position.lng;
                        } else {
                            throw new Error(d.message);
                        }
                    } catch (err) {
                        Swal.fire('Gagal', err.message, 'error');
                        marker.setLatLng([obj.lat, obj.lng]); // revert
                    }
                } else {
                    marker.setLatLng([obj.lat, obj.lng]); // revert
                }
            });
        });

        cableGroup.clearLayers();
        initialCables.forEach(cb => {
            const poly = L.polyline(cb.path, { 
                color: cb.color || '#3b82f6', 
                weight: 4, 
                opacity: 0.7,
                className: 'flow-line' // Add flow animation to main cables
            }).addTo(cableGroup);
            
            poly.bindPopup(`
                <span class="popup-title">${cb.name || t.main_cable_path}</span>
                <button class="btn-delete" onclick="deleteCable(${cb.id})"><i class="fas fa-trash"></i> ${t.delete}</button>
            `);
        });

        // Fit Bounds if first load
        if(!window.mapInitialized) {
            const allLayers = [];
            customerGroup.eachLayer(l => allLayers.push(l));
            objectGroup.eachLayer(l => allLayers.push(l));
            if(allLayers.length > 0) {
                const group = new L.featureGroup(allLayers);
                map.fitBounds(group.getBounds().pad(0.1));
                window.mapInitialized = true;
            }
        }
    }

    renderMarkers();

    // Sync Redaman Real-time
    map.on('popupopen', async function(e) {
        const layer = e.popup._source;
        if (layer && layer.options && layer.options.customerData) {
            const c = layer.options.customerData;
            if (c.olt_id && c.onu_index) {
                const el = document.getElementById('rx-map-' + c.id);
                if (el) {
                    el.innerHTML = `Redaman: <i class="fas fa-circle-notch fa-spin"></i> Sync...`;
                    try {
                        const res = await fetch(`/api/onu-info?olt_id=${c.olt_id}&index=${encodeURIComponent(c.onu_index)}`);
                        const d = await res.json();
                        if (d.success) {
                            const power = parseFloat(d.rx_power);
                            const isBad = power < -26 || power > -8;
                            el.innerHTML = `Redaman: <b>${d.rx_power} dBm</b> (${d.status})`;
                            el.parentElement.querySelector('.fas.fa-signal').style.color = isBad ? '#EF4444' : '#10B981';
                        } else {
                            el.innerHTML = `Redaman: <b>${c.redaman} dBm</b> <span style="color:#EF4444;font-size:10px">[Gagal]</span>`;
                        }
                    } catch(err) {
                        el.innerHTML = `Redaman: <b>${c.redaman} dBm</b> <span style="color:#EF4444;font-size:10px">[Timeout]</span>`;
                    }
                }
            }
        }
    });

    function handleConnectMode(marker) {
        if (!connectSource) {
            connectSource = marker;
            marker._icon.style.filter = 'drop-shadow(0 0 10px #3b82f6)';
            Swal.fire({
                title: t.step_2,
                text: t.connect_step_2_desc.replace('{name}', marker.objData.name),
                icon: 'info', toast: true, position: 'top-end', timer: 3000, showConfirmButton: false
            });
        } else {
            if (connectSource === marker) {
                connectSource = null;
                marker._icon.style.filter = '';
                return;
            }
            
            const source = connectSource.objData;
            const target = marker.objData;
            
            // Create straight cable
            saveCable(`${t.draw_cable} ${source.name} - ${target.name}`, [[source.lat, source.lng], [target.lat, target.lng]]);
            
            connectSource._icon.style.filter = '';
            connectSource = null;
        }
    }

    // Interaction Logic
    function setMode(mode) {
        currentMode = mode;
        connectSource = null;
        document.querySelectorAll('.tool-btn').forEach(b => b.classList.remove('active'));
        if(mode) document.getElementById(`btn-${mode}`).classList.add('active');
        
        if (mode === 'connect') {
            Swal.fire({
                title: t.connect_mode_title,
                text: t.connect_mode_desc,
                icon: 'info', toast: true, position: 'top-end', timer: 4000, showConfirmButton: false
            });
        } else if (mode) {
            Swal.fire({
                title: t.active_customer,
                text: `${t.toolbox_info} ${mode.toUpperCase()}`,
                icon: 'info', toast: true, position: 'top-end', timer: 3000, showConfirmButton: false
            });
        }
    }

    function resetMode() {
        setMode(null);
        polylineDrawer.disable();
    }

    map.on('click', async (e) => {
        if (!currentMode || currentMode === 'connect') return;
        
        const { lat, lng } = e.latlng;
        const { value: name } = await Swal.fire({
            title: t.enter_name.replace('{type}', currentMode.toUpperCase()),
            input: 'text',
            inputPlaceholder: t.example_name,
            showCancelButton: true,
            inputValidator: (value) => {
                if (!value) return t.name_required;
            }
        });

        if (name) {
            Swal.fire({ title: t.saving, allowOutsideClick: false, didOpen: () => { Swal.showLoading() } });
            try {
                const resp = await fetch('/map/api/objects', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ name, type: currentMode, lat, lng })
                });
                
                const res = await resp.json();
                if (res.success) {
                    Swal.fire({ icon: 'success', title: t.success_msg, text: t.device_saved, timer: 1500 });
                    setTimeout(() => location.reload(), 1500);
                } else {
                    throw new Error(res.message || t.failed_to_save);
                }
            } catch (err) {
                Swal.fire({ icon: 'error', title: 'Error', text: err.message });
            }
        }
    });

    // Cable Drawing
    const polylineDrawer = new L.Draw.Polyline(map, {
        shapeOptions: { color: selectedCableColor, weight: 4 }
    });

    function startDrawCable() {
        setMode(null);
        document.getElementById('btn-cable').classList.add('active');
        polylineDrawer.enable();
    }

    // SNAPPING LOGIC
    map.on('mousemove', (e) => {
        // We could implement visual snapping here if needed
    });

    map.on(L.Draw.Event.CREATED, async (e) => {
        const layer = e.layer;
        let latlngs = layer.getLatLngs();
        
        if (Array.isArray(latlngs[0]) && !latlngs[0].lat) latlngs = latlngs[0];
        
        // Apply Snapping to all points
        const snappedPath = latlngs.map(ll => {
            let snapped = [ll.lat, ll.lng];
            let minDist = 20; // 20 meters snap radius
            
            initialObjects.forEach(obj => {
                const d = map.distance([ll.lat, ll.lng], [obj.lat, obj.lng]);
                if (d < minDist) {
                    snapped = [obj.lat, obj.lng];
                    minDist = d;
                }
            });
            return snapped;
        });
        
        const { value: name } = await Swal.fire({
            title: t.main_cable_path,
            input: 'text',
            inputPlaceholder: t.example_name,
            showCancelButton: true,
            inputValidator: (value) => {
                if (!value) return t.name_required;
            }
        });

        if (name) saveCable(name, snappedPath);
        document.getElementById('btn-cable').classList.remove('active');
    });

    async function saveCable(name, path) {
        Swal.fire({ title: t.saving, allowOutsideClick: false, didOpen: () => { Swal.showLoading() } });
        try {
            const resp = await fetch('/map/api/cables', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ name, path, color: selectedCableColor })
            });

            const res = await resp.json();
            if (res.success) {
                Swal.fire({ icon: 'success', title: t.success_msg, text: t.cable_saved, timer: 1500 });
                setTimeout(() => location.reload(), 1500);
            } else {
                throw new Error(res.message || t.failed_to_save);
            }
        } catch (err) {
            Swal.fire({ icon: 'error', title: 'Error', text: err.message });
        }
    }

    // Delete Logic
    async function editObject(id) {
        const obj = initialObjects.find(o => o.id === id);
        if (!obj) return;

        const { value: formValues } = await Swal.fire({
            title: 'Edit ' + obj.type.toUpperCase(),
            html:
                `<div style="text-align:left; font-size:13px; margin-bottom:5px; color:var(--muted)">Nama Perangkat</div>` +
                `<input id="swal-input1" class="swal2-input" style="width:100%; margin:0 0 15px 0" placeholder="Nama" value="${obj.name}">` +
                `<div style="text-align:left; font-size:13px; margin-bottom:5px; color:var(--muted)">Latitude</div>` +
                `<input id="swal-input2" class="swal2-input" style="width:100%; margin:0 0 15px 0" placeholder="Latitude" value="${obj.lat}">` +
                `<div style="text-align:left; font-size:13px; margin-bottom:5px; color:var(--muted)">Longitude</div>` +
                `<input id="swal-input3" class="swal2-input" style="width:100%; margin:0" placeholder="Longitude" value="${obj.lng}">`,
            focusConfirm: false,
            showCancelButton: true,
            confirmButtonText: 'Simpan',
            cancelButtonText: 'Batal',
            preConfirm: () => {
                return [
                    document.getElementById('swal-input1').value,
                    document.getElementById('swal-input2').value,
                    document.getElementById('swal-input3').value
                ]
            }
        });

        if (formValues) {
            const [name, lat, lng] = formValues;
            if(!name || !lat || !lng) {
                Swal.showValidationMessage('Semua harus diisi');
                return;
            }
            try {
                const res = await fetch(`/map/api/objects/${obj.id}`, {
                    method: 'PUT',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({ name, lat, lng })
                });
                const d = await res.json();
                if (d.success) {
                    Swal.fire('Tersimpan!', 'Perangkat berhasil diperbarui.', 'success').then(() => location.reload());
                } else {
                    Swal.fire('Gagal', d.message, 'error');
                }
            } catch (err) {
                Swal.fire('Gagal', err.message, 'error');
            }
        }
    }

    async function deleteObject(id) {
        if (!confirm(t.delete_confirm)) return;
        const resp = await fetch(`/map/api/objects/${id}`, { method: 'DELETE' });
        const res = await resp.json();
        if (res.success) location.reload();
    }

    async function deleteCable(id) {
        if (!confirm(t.delete_confirm)) return;
        const resp = await fetch(`/map/api/cables/${id}`, { method: 'DELETE' });
        const res = await resp.json();
        if (res.success) location.reload();
    }

    // New Functions
    function toggleLayer(type, el) {
        el.classList.toggle('active');
        const groups = {
            customers: customerGroup,
            objects: objectGroup,
            cables: cableGroup,
            dropCables: dropCableGroup
        };
        const group = groups[type];
        if (el.classList.contains('active')) map.addLayer(group);
        else map.removeLayer(group);
    }

    function searchMap() {
        const query = document.getElementById('searchInput').value.toLowerCase();
        const results = document.getElementById('searchResults');
        if (query.length < 2) { results.style.display = 'none'; return; }

        let html = '';
        const combined = [
            ...customers.map(c => ({ ...c, mapType: t.customers, group: customerGroup })),
            ...initialObjects.map(o => ({ ...o, mapType: o.type.toUpperCase(), group: objectGroup }))
        ];

        const filtered = combined.filter(item => item.name.toLowerCase().includes(query)).slice(0, 10);
        
        if (filtered.length > 0) {
            html = filtered.map(item => `
                <div class="search-item" onclick="focusItem(${item.lat}, ${item.lng}, '${item.name}')">
                    <span>${item.name}</span>
                    <span style="font-size:10px; opacity:0.6">${item.mapType}</span>
                </div>
            `).join('');
            results.innerHTML = html;
            results.style.display = 'block';
        } else {
            results.style.display = 'none';
        }
    }

    function focusItem(lat, lng, name) {
        map.setView([lat, lng], 18);
        document.getElementById('searchResults').style.display = 'none';
        document.getElementById('searchInput').value = name;
        
        // Find and open popup
        [customerGroup, objectGroup].forEach(group => {
            group.eachLayer(layer => {
                if (layer.getLatLng && layer.getLatLng().lat == lat && layer.getLatLng().lng == lng) {
                    layer.openPopup();
                }
            });
        });
    }

    function locateUser() {
        map.locate({setView: true, maxZoom: 16});
    }

    map.on('locationfound', (e) => {
        L.marker(e.latlng).addTo(map).bindPopup(t.your_location).openPopup();
    });

    map.on('locationerror', (e) => {
        Swal.fire('Error', 'Gagal mendapatkan lokasi: ' + e.message, 'error');
    });

    // Close search results on click outside
    document.addEventListener('click', (e) => {
        if (!e.target.closest('.map-search')) {
            document.getElementById('searchResults').style.display = 'none';
            collapseSearch();
        }
    });

    function expandSearch() {
        const wrapper = document.getElementById('searchWrapper');
        wrapper.classList.add('expanded');
        document.getElementById('searchInput').focus();
    }
    
    function collapseSearch(e) {
        if (e) e.stopPropagation();
        const wrapper = document.getElementById('searchWrapper');
        wrapper.classList.remove('expanded');
        const input = document.getElementById('searchInput');
        if (input) input.value = '';
        const results = document.getElementById('searchResults');
        if (results) results.style.display = 'none';
    }

</script>
</body>
</html>
