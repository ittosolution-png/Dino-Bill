<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('partials/head') %>
    <title>Dino-Bill | Peta Pelanggan</title>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <style>
        #map { flex:1; width:100%; z-index:10; }
        .map-overlay { position:absolute; top:80px; right:20px; z-index:100; background:rgba(15,23,42,.9); padding:15px; border-radius:12px; border:1px solid var(--border); width:250px; }
        .map-overlay h3 { margin:0 0 10px; font-size:14px; }
        .legend-item { display:flex; align-items:center; gap:8px; font-size:12px; margin-bottom:5px; }
        .dot { width:10px; height:10px; border-radius:50%; }
        @media(max-width:768px) { .map-overlay { top:auto; bottom:20px; right:10px; left:10px; width:auto; display:flex; flex-wrap:wrap; gap:15px; } .map-overlay h3 { width:100%; margin-bottom:5px; } }
    </style>
</head>
<body>
<%- include('partials/sidebar') %>
<main class="main">
    <%- include('partials/topbar', { title: 'Sebaran Lokasi Pelanggan' }) %>
    <div id="map"></div>
    <div class="map-overlay">
        <h3>Legend</h3>
        <div class="legend-item"><div class="dot" style="background:var(--success)"></div> Aktif</div>
        <div class="legend-item"><div class="dot" style="background:var(--danger)"></div> Terisolir</div>
        <hr style="border-color:var(--border);margin:10px 0;">
        <p style="font-size:11px;color:var(--muted);margin:0">Total Pelanggan Terpetakan: <b id="mapCount">0</b></p>
    </div>
</main>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
    const map = L.map('map').setView([-6.200000, 106.816666], 13);
    L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; <a href="https://carto.com/attributions">CARTO</a>'
    }).addTo(map);

    const customers = <%- JSON.stringify(customers) %>;
    let count = 0;
    
    customers.forEach(c => {
        if(c.lat && c.lng) {
            const marker = L.circleMarker([c.lat, c.lng], {
                radius: 8,
                fillColor: c.status === 'active' ? '#10B981' : '#EF4444',
                color: "#fff",
                weight: 2,
                opacity: 1,
                fillOpacity: 0.8
            }).addTo(map);
            
            marker.bindPopup(`
                <div style="color:#000">
                    <b style="font-size:14px">${c.name}</b><br>
                    <span style="font-size:12px">${c.address || '-'}</span><br>
                    <span style="font-size:12px;color:${c.status === 'active' ? 'green' : 'red'}">${c.status.toUpperCase()}</span>
                </div>
            `);
            count++;
        }
    });

    document.getElementById('mapCount').innerText = count;
    if(count > 0) {
        const group = new L.featureGroup(customers.filter(c => c.lat && c.lng).map(c => L.marker([c.lat, c.lng])));
        map.fitBounds(group.getBounds().pad(0.1));
    }
</script>
</body>
</html>
