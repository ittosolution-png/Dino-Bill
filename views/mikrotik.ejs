<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('partials/head') %>
    <style>
        .badge-online{background:rgba(16,185,129,.1);color:var(--success);border:1px solid rgba(16,185,129,.2);padding:4px 10px;border-radius:20px;font-size:11px;font-weight:600;}
        .overlay{position:fixed;top:0;left:0;right:0;bottom:0;background:var(--overlay-bg);backdrop-filter:blur(4px);display:none;align-items:center;justify-content:center;z-index:999;}
        .modal{background:var(--modal-bg);border:1px solid var(--border);border-radius:20px;width:100%;max-width:480px;padding:28px;}
        .modal-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;}.modal-title{font-size:18px;font-weight:600;margin:0;}.close-btn{background:none;border:none;color:var(--muted);font-size:22px;cursor:pointer;}
        .form-group{margin-bottom:14px;}.form-group label{display:block;margin-bottom:6px;font-size:13px;color:var(--muted);}
        .form-row{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
        .toast{position:fixed;bottom:24px;right:24px;background:var(--toast-bg);color:var(--text);border:1px solid var(--border);border-radius:12px;padding:14px 20px;z-index:9999;display:none;font-size:14px;}.toast.show{display:block;}
        @media(max-width:768px){.form-row{grid-template-columns:1fr;}}
        .spinner { border: 3px solid rgba(255,255,255,0.1); border-radius: 50%; border-top: 3px solid var(--primary); width: 30px; height: 30px; animation: spin 1s linear infinite; margin: 0 auto 15px auto; }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
    </style>
</head>
<body>
<%- include('partials/sidebar') %>
<main class="main">
    <%- include('partials/topbar', { title: t.mikrotik }) %>
    <div class="content">
        <div class="page-header" style="margin-bottom:20px">
            <h1 class="page-title" id="pageTitle"><%= t.router_management %></h1>
            <div style="display:flex;gap:10px;">
                <button class="btn btn-primary" id="addRouterBtn" onclick="openModal('add')">+ <%= t.add_router %></button>
                <button class="btn btn-primary" id="refreshPppoeBtn" onclick="loadPppoeActive()" style="display:none;background:rgba(59,130,246,.15);color:var(--primary);border:1px solid rgba(59,130,246,.3)">🔄 Refresh</button>
            </div>
        </div>

        <!-- Modern Premium Tabs -->
        <div class="tabs-container" style="display:flex;gap:12px;margin-bottom:25px;border-bottom:1px solid var(--border);padding-bottom:12px;">
            <button class="tab-btn active" onclick="switchTab('routers')" id="tabBtnRouters" style="background:var(--hover-bg);border:none;color:var(--text);font-size:14px;font-weight:600;padding:10px 18px;cursor:pointer;border-radius:10px;transition:all 0.2s;font-family:'Outfit',sans-serif;">
                <i class="fa-solid fa-server" style="margin-right:6px;"></i><%= t.router_management %>
            </button>
            <button class="tab-btn" onclick="switchTab('pppoe')" id="tabBtnPppoe" style="background:none;border:none;color:var(--muted);font-size:14px;font-weight:600;padding:10px 18px;cursor:pointer;border-radius:10px;transition:all 0.2s;font-family:'Outfit',sans-serif;">
                <i class="fa-solid fa-users" style="margin-right:6px;"></i>PPPoE Active Users
            </button>
        </div>

        <!-- Router Tab Content -->
        <div id="tabRoutersContent">
            <div class="card">
                <table>
                    <thead><tr><th><%= t.name %></th><th><%= t.ip_address %></th><th><%= t.username %></th><th><%= t.api_port %></th><th><%= t.status %></th><th><%= t.action %></th></tr></thead>
                    <tbody>
                    <% if (routers && routers.length > 0) { %>
                        <% routers.forEach(r => { %>
                        <tr>
                            <td style="font-weight:600"><%= r.name %></td>
                            <td><code style="background:rgba(255,255,255,.08);padding:2px 8px;border-radius:6px"><%= r.ip_address %></code></td>
                            <td><%= r.username %></td>
                            <td><%= r.port || 8728 %></td>
                            <td>
                                <% if (r.online) { %>
                                <span class="badge-online">● <%= t.online %></span>
                                <% } else { %>
                                <span style="background:rgba(239,68,68,.1);color:var(--danger);border:1px solid rgba(239,68,68,.2);padding:4px 10px;border-radius:20px;font-size:11px;font-weight:600">● <%= t.offline %></span>
                                <% } %>
                            </td>
                            <td>
                                <div style="display:flex;gap:10px;flex-wrap:wrap">
                                    <button class="btn btn-sm btn-info" onclick='openModal("edit",<%- JSON.stringify(r) %>)'><%= t.edit %></button>
                                    <button class="btn btn-sm" style="background:rgba(16,185,129,.15);color:var(--success);border:1px solid rgba(16,185,129,.3)" onclick="syncRouter(<%= r.id %>)">⟳ Sync</button>
                                    <button class="btn btn-sm" style="background:rgba(139,92,246,.15);color:var(--secondary);border:1px solid rgba(139,92,246,.3)" onclick="checkRouter(<%= r.id %>)">📡 Check</button>
                                    <button class="btn btn-sm btn-danger" onclick="deleteItem('/mikrotik/api/<%= r.id %>','<%= t.confirm_delete_router %>')"><%= t.delete %></button>
                                </div>
                            </td>
                        </tr>
                        <% }); %>
                    <% } else { %>
                        <tr><td colspan="6" style="text-align:center;color:var(--muted);padding:50px 0"><%= t.no_customer_data %></td></tr>
                    <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- PPPoE Active Tab Content -->
        <div class="card" id="tabPppoeContent" style="display:none;overflow-x:auto;">
            <div class="search-container" style="margin-bottom:20px;display:flex;gap:15px;align-items:center;flex-wrap:wrap;">
                <input type="text" id="pppoeSearch" class="form-control" placeholder="Cari username, IP, MAC, atau Router..." style="max-width:350px">
                <div style="font-size:14px;color:var(--muted)" id="pppoeCount">Total: <strong>0</strong> User Online</div>
            </div>
            
            <div id="pppoeLoader" style="text-align:center;padding:50px 0;color:var(--muted);">
                <div class="spinner" style="border: 3px solid rgba(255,255,255,0.1); border-radius: 50%; border-top: 3px solid var(--primary); width: 30px; height: 30px; animation: spin 1s linear infinite; margin: 0 auto 15px auto;"></div>
                <span>Menghubungi semua router MikroTik...</span>
            </div>

            <table id="pppoeTableContainer" style="display:none;">
                <thead>
                    <tr>
                        <th>Username</th>
                        <th>IP Address</th>
                        <th>Caller ID (MAC)</th>
                        <th>Uptime</th>
                        <th>Router</th>
                    </tr>
                </thead>
                <tbody id="pppoeTableBody">
                    <!-- Dynamic Rows -->
                </tbody>
            </table>
        </div>
    </div>
</main>

<div class="overlay" id="modalOverlay" onclick="if(event.target===this)closeModal()">
    <div class="modal" onclick="event.stopPropagation()">
        <div class="modal-header"><h2 class="modal-title" id="modalTitle"><%= t.add_router %></h2><button class="close-btn" onclick="closeModal()">×</button></div>
        <form id="routerForm">
            <input type="hidden" id="routerId">
            <div class="form-group"><label><%= t.name %> *</label><input type="text" id="rName" class="form-control" required placeholder="<%= t.example_router_name %>"></div>
            <div class="form-row">
                <div class="form-group"><label><%= t.ip_address %> *</label><input type="text" id="rIP" class="form-control" required placeholder="192.168.1.1"></div>
                <div class="form-group"><label><%= t.api_port %></label><input type="number" id="rPort" class="form-control" value="8728"></div>
            </div>
            <div class="form-row">
                <div class="form-group"><label><%= t.username %> *</label><input type="text" id="rUser" class="form-control" required placeholder="admin"></div>
                <div class="form-group"><label><%= t.password %></label><input type="password" id="rPass" class="form-control" placeholder="password"></div>
            </div>
            <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;padding:13px;margin-top:6px"><%= t.save %></button>
        </form>
    </div>
</div>
<div class="toast" id="toast"></div>
<script>
let editMode=false;

// Tab switcher logic
function switchTab(tab) {
    const tabRouters = document.getElementById('tabRoutersContent');
    const tabPppoe = document.getElementById('tabPppoeContent');
    const btnRouters = document.getElementById('tabBtnRouters');
    const btnPppoe = document.getElementById('tabBtnPppoe');
    const titleEl = document.getElementById('pageTitle');
    
    if (tab === 'routers') {
        tabRouters.style.display = 'block';
        tabPppoe.style.display = 'none';
        
        btnRouters.style.color = 'var(--text)';
        btnRouters.style.background = 'var(--hover-bg)';
        btnPppoe.style.color = 'var(--muted)';
        btnPppoe.style.background = 'none';
        
        document.getElementById('addRouterBtn').style.display = 'inline-flex';
        document.getElementById('refreshPppoeBtn').style.display = 'none';
        titleEl.textContent = '<%= t.router_management %>';
    } else {
        tabRouters.style.display = 'none';
        tabPppoe.style.display = 'block';
        
        btnPppoe.style.color = 'var(--text)';
        btnPppoe.style.background = 'var(--hover-bg)';
        btnRouters.style.color = 'var(--muted)';
        btnRouters.style.background = 'none';
        
        document.getElementById('addRouterBtn').style.display = 'none';
        document.getElementById('refreshPppoeBtn').style.display = 'inline-flex';
        titleEl.textContent = 'PPPoE Active Users';
        
        loadPppoeActive();
    }
}

// Fetch active PPPoE connections dynamically via AJAX
async function loadPppoeActive() {
    const loader = document.getElementById('pppoeLoader');
    const table = document.getElementById('pppoeTableContainer');
    const body = document.getElementById('pppoeTableBody');
    const countEl = document.getElementById('pppoeCount');
    
    loader.style.display = 'block';
    table.style.display = 'none';
    body.innerHTML = '';
    
    try {
        const res = await fetch('/mikrotik/api/pppoe-active');
        const d = await res.json();
        
        if (d.success && d.data) {
            if (d.data.length === 0) {
                body.innerHTML = '<tr><td colspan="5" style="text-align:center;color:var(--muted);padding:50px 0">Tidak ada user PPPoE yang aktif saat ini.</td></tr>';
            } else {
                d.data.forEach(c => {
                    const row = document.createElement('tr');
                    row.innerHTML = `
                        <td><code style="background:rgba(255,255,255,.08);padding:4px 10px;border-radius:6px;font-size:13px;font-weight:600;">${c.name}</code></td>
                        <td><code>${c.address}</code></td>
                        <td style="font-size:12px;color:var(--muted);">${c.callerid || '-'}</td>
                        <td><span style="background:rgba(59,130,246,.1);color:var(--primary);border:1px solid rgba(59,130,246,.2);padding:2px 8px;border-radius:6px;font-size:12px;display:inline-flex;align-items:center;gap:4px;">⏱ ${c.uptime}</span></td>
                        <td>
                            <span style="font-size:13px;font-weight:500;color:var(--secondary)">🖥 ${c.routerName}</span>
                        </td>
                    `;
                    body.appendChild(row);
                });
            }
            countEl.innerHTML = `Total: <strong>${d.data.length}</strong> User Online`;
        } else {
            body.innerHTML = `<tr><td colspan="5" style="text-align:center;color:var(--danger);padding:50px 0">Gagal mengambil data: ${d.message}</td></tr>`;
        }
    } catch (e) {
        body.innerHTML = `<tr><td colspan="5" style="text-align:center;color:var(--danger);padding:50px 0">Error: ${e.message}</td></tr>`;
    } finally {
        loader.style.display = 'none';
        table.style.display = 'table';
    }
}

// Live search in dynamic table
document.getElementById('pppoeSearch').addEventListener('input', function(e) {
    const q = e.target.value.toLowerCase();
    const rows = document.querySelectorAll('#pppoeTableBody tr');
    rows.forEach(r => {
        if(r.cells.length > 1) {
            r.style.display = r.textContent.toLowerCase().includes(q) ? '' : 'none';
        }
    });
});

function openModal(mode,data){
    editMode=mode==='edit';
    document.getElementById('modalTitle').textContent=editMode? '<%= t.edit_router %>' : '<%= t.add_router %>';
    if(editMode&&data){document.getElementById('routerId').value=data.id;document.getElementById('rName').value=data.name||'';document.getElementById('rIP').value=data.ip_address||'';document.getElementById('rPort').value=data.port||8728;document.getElementById('rUser').value=data.username||'';document.getElementById('rPass').value='';}
    else{document.getElementById('routerForm').reset();document.getElementById('routerId').value='';document.getElementById('rPort').value=8728;}
    document.getElementById('modalOverlay').style.display='flex';
}
function closeModal(){document.getElementById('modalOverlay').style.display='none';}
document.getElementById('routerForm').addEventListener('submit',async(e)=>{
    e.preventDefault();
    const id=document.getElementById('routerId').value;
    const body={name:document.getElementById('rName').value,ip_address:document.getElementById('rIP').value,port:document.getElementById('rPort').value,username:document.getElementById('rUser').value,password:document.getElementById('rPass').value};
    const res=await fetch(editMode?`/mikrotik/api/${id}`:'/mikrotik/api/add',{method:editMode?'PUT':'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
    const d=await res.json();showToast(d.message,d.success?'success':'error');
    if(d.success){closeModal();setTimeout(()=>location.reload(),1000);}
});
async function deleteItem(url,msg){if(!confirm(msg))return;const res=await fetch(url,{method:'DELETE'});const d=await res.json();showToast(d.message,d.success?'success':'error');if(d.success)setTimeout(()=>location.reload(),1000);}
async function syncRouter(id){
    showToast('⏳ <%= t.syncing_mikrotik %>','success');
    const res=await fetch(`/mikrotik/api/${id}/sync`,{method:'POST'});
    const d=await res.json();
    showToast(d.message,d.success?'success':'error');
    if(d.success)setTimeout(()=>location.reload(),2000);
}
async function checkRouter(id){
    showToast('⏳ <%= t.checking_router_status %>','success');
    const res=await fetch(`/mikrotik/api/${id}/check`,{method:'POST'});
    const d=await res.json();
    showToast(d.message,d.success?'success':'error');
}
function showToast(msg,type){const t=document.getElementById('toast');t.textContent=msg;t.style.borderColor=type==='success'?'rgba(16,185,129,.4)':'rgba(239,68,68,.4)';t.style.color=type==='success'?'#10B981':'#EF4444';t.classList.add('show');setTimeout(()=>t.classList.remove('show'),4000);}
</script>
</body>
</html>
