<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('partials/head') %>
    <style>
        .card{background:var(--card-bg);border:1px solid var(--border);border-radius:16px;padding:24px;margin-bottom:20px;overflow-x:auto;}
        .badge-up{background:rgba(16,185,129,.1);color:var(--success);border:1px solid rgba(16,185,129,.2);}
        .badge-down{background:rgba(239,68,68,.1);color:var(--danger);border:1px solid rgba(239,68,68,.2);}
    </style>
</head>
<body>
<%- include('partials/sidebar') %>
<main class="main">
    <%- include('partials/topbar', { title: 'GenieACS Management' }) %>
    <div class="content">
        <div class="page-header" style="margin-bottom:25px">
            <h1 class="page-title">Monitoring ONT (GenieACS)</h1>
            <div style="display:flex;gap:25px;align-items:center">
                <button class="btn btn-primary" onclick="refreshACS()">🔄 Refresh Data</button>
            </div>
        </div>

        <div class="card">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:15px">
                <h3 style="margin:0;font-size:16px">Daftar Perangkat Terdeteksi</h3>
                <input type="text" id="acsSearch" class="form-control" placeholder="Cari SN, Model, atau IP..." style="width:250px">
            </div>
            <table>
                <thead>
                    <tr>
                        <th>Serial Number</th>
                        <th>Model</th>
                        <th>PPPoE User</th>
                        <th>IP Address</th>
                        <% vParams.forEach(p => { %>
                        <th><%= p.split('.').pop() %></th>
                        <% }); %>
                        <th>Last Inform</th>
                        <th>Status</th>
                        <th>Aksi</th>
                    </tr>
                </thead>
                <tbody id="acsTable">
                <% if(devices && devices.length > 0) { %>
                    <% devices.forEach(d => { %>
                    <tr>
                        <td><code><%= d.sn %></code></td>
                        <td style="font-weight:600"><%= d.product_class || d.manufacturer %></td>
                        <td><code style="background:rgba(255,255,255,.08);padding:2px 8px;border-radius:6px;font-size:12px;color:var(--primary)"><%= d.pppoe_user %></code></td>
                        <td><code><%= d.ip_address %></code></td>
                        <% vParams.forEach(p => { %>
                        <td><span style="font-size:12px; font-family:monospace;"><%= d.vparams[p] || '-' %></span></td>
                        <% }); %>
                        <td style="font-size:12px"><%= d.last_inform ? new Date(d.last_inform).toLocaleString('id-ID') : '-' %></td>
                        <td>
                            <span class="badge <%= d.isOnline ? 'badge-up' : 'badge-down' %>"><%= d.isOnline ? '● Online' : '● Offline' %></span>
                        </td>
                        <td>
                            <div style="display:flex;gap:12px;flex-wrap:wrap">
                                <button class="btn" style="padding:4px 12px;font-size:11px;border-radius:6px;background:rgba(59,130,246,.12);color:var(--primary);border:1px solid rgba(59,130,246,.25)" onclick="refreshDevice('<%= d.id %>')">🔄 Refresh</button>
                                <button class="btn" style="padding:4px 12px;font-size:11px;border-radius:6px;background:rgba(245,158,11,.12);color:var(--warning);border:1px solid rgba(245,158,11,.25)" onclick="rebootDevice('<%= d.id %>')">⟳ Reboot</button>
                                <button class="btn" style="padding:4px 12px;font-size:11px;border-radius:6px;background:rgba(239,68,68,.12);color:var(--danger);border:1px solid rgba(239,68,68,.25)" onclick="factoryReset('<%= d.id %>')">⚠ Reset</button>
                            </div>
                        </td>
                    </tr>
                    <% }); %>
                <% } else { %>
                    <tr><td colspan="<%= 7 + vParams.length %>" style="text-align:center;color:var(--muted);padding:40px">
                        <% if (!acsUrl) { %>
                        Belum ada URL GenieACS yang dikonfigurasi. <a href="/settings" style="color:var(--primary)">Atur di Pengaturan →</a>
                        <% } else if (!acsOnline) { %>
                        Gagal terhubung ke GenieACS (<%= acsUrl %>). Pastikan server ACS berjalan.
                        <% } else { %>
                        Belum ada perangkat terdeteksi di GenieACS.
                        <% } %>
                    </td></tr>
                <% } %>
                </tbody>
            </table>
        </div>

        <% if (acsUrl) { %>
        <div style="font-size:12px;color:var(--muted);display:flex;align-items:center;gap:8px">
            <span style="width:8px;height:8px;border-radius:50%;background:<%= acsOnline ? 'var(--success)' : 'var(--danger)' %>;display:inline-block"></span>
            GenieACS: <%= acsUrl %> — <%= acsOnline ? 'Connected' : 'Disconnected' %>
            | <%= devices.length %> devices
        </div>
        <% } %>
    </div>
</main>
<div class="toast" id="toast" style="position:fixed;bottom:24px;right:24px;background:#111827;border:1px solid var(--border);border-radius:12px;padding:14px 20px;z-index:9999;display:none;font-size:14px;"></div>
<script>
document.getElementById('acsSearch').addEventListener('input', function(e) {
    const q = e.target.value.toLowerCase();
    const rows = document.querySelectorAll('#acsTable tr');
    rows.forEach(r => {
        r.style.display = r.textContent.toLowerCase().includes(q) ? '' : 'none';
    });
});

async function refreshACS() {
    location.reload();
}

async function rebootDevice(deviceId) {
    if (!confirm('Reboot perangkat ini?')) return;
    showToast('⏳ Mengirim perintah reboot...', 'success');
    const res = await fetch(`/acs/api/reboot/${encodeURIComponent(deviceId)}`, { method: 'POST' });
    const d = await res.json();
    showToast(d.message, d.success ? 'success' : 'error');
}

async function refreshDevice(deviceId) {
    showToast('⏳ Mengirim refresh parameter...', 'success');
    const res = await fetch(`/acs/api/refresh/${encodeURIComponent(deviceId)}`, { method: 'POST' });
    const d = await res.json();
    showToast(d.message, d.success ? 'success' : 'error');
}

async function factoryReset(deviceId) {
    if (!confirm('⚠️ PERINGATAN: Factory reset akan menghapus semua konfigurasi perangkat! Lanjutkan?')) return;
    showToast('⏳ Mengirim factory reset...', 'success');
    const res = await fetch(`/acs/api/factory-reset/${encodeURIComponent(deviceId)}`, { method: 'POST' });
    const d = await res.json();
    showToast(d.message, d.success ? 'success' : 'error');
}

function showToast(msg,type){const t=document.getElementById('toast');t.textContent=msg;t.style.borderColor=type==='success'?'rgba(16,185,129,.4)':'rgba(239,68,68,.4)';t.style.color=type==='success'?'#10B981':'#EF4444';t.style.display='block';setTimeout(()=>t.style.display='none',4000);}
</script>
</body>
</html>

