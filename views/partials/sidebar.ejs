<div class="sidebar">
    <div class="sidebar-brand">
        <i class="fa-solid fa-dragon me-2"></i>Dino-Bill
    </div>

    <div class="nav-menu">
        <div class="nav-section"><%= t.main %></div>
        <a href="/" class="nav-item <%= currentPage === 'dashboard' ? 'active' : '' %>">
            <i class="fa-solid fa-house"></i> <%= t.dashboard %>
        </a>
        <a href="/customers" class="nav-item <%= currentPage === 'customers' ? 'active' : '' %>">
            <i class="fa-solid fa-users"></i> <%= t.customers %>
        </a>
        <a href="/billing" class="nav-item <%= currentPage === 'billing' ? 'active' : '' %>">
            <i class="fa-solid fa-file-invoice-dollar"></i> <%= t.billing %>
        </a>

        <div class="nav-section"><%= t.infrastructure %></div>
        <a href="/mikrotik" class="nav-item <%= currentPage === 'mikrotik' ? 'active' : '' %>">
            <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="margin-right:0px;"><path d="M8.111 16.404a5.5 5.5 0 017.778 0M12 20h.01m-7.08-7.071a9.9 9.9 0 0114.142 0M12 4c4.418 0 8 3.582 8 8a8 8 0 01-8 8 8 8 0 01-8-8c0-4.418 3.582-8 8-8z"/></svg>
            MikroTik
        </a>
        <a href="/olt" class="nav-item <%= currentPage === 'olt' ? 'active' : '' %>">
            <i class="fa-solid fa-server"></i> <%= t.olt_management %>
        </a>
        <a href="/acs" class="nav-item <%= currentPage === 'acs' ? 'active' : '' %>">
            <i class="fa-solid fa-microchip"></i> <%= t.genieacs %>
        </a>
        <a href="/packages" class="nav-item <%= currentPage === 'packages' ? 'active' : '' %>">
            <i class="fa-solid fa-box-archive"></i> <%= t.internet_packages %>
        </a>

        <div class="nav-section"><%= t.operations %></div>
        <a href="/tickets" class="nav-item <%= currentPage === 'tickets' ? 'active' : '' %>">
            <i class="fa-solid fa-ticket"></i> <%= t.tickets %>
        </a>
        <a href="/map" class="nav-item <%= currentPage === 'map' ? 'active' : '' %>">
            <i class="fa-solid fa-map-location-dot"></i> <%= t.map %>
        </a>
        <a href="/hotspot" class="nav-item <%= currentPage === 'hotspot' ? 'active' : '' %>">
            <i class="fa-solid fa-wifi"></i> Hotspot
        </a>
        <a href="/inventory" class="nav-item <%= currentPage === 'inventory' ? 'active' : '' %>">
            <i class="fa-solid fa-boxes-stacked"></i> <%= t.inventory %>
        </a>

        <div class="nav-section">Plugins</div>
        <a href="/plugins" class="nav-item <%= currentPage === 'plugins' ? 'active' : '' %>">
            <i class="fa-solid fa-puzzle-piece"></i> Plugins
        </a>

        <% if (locals.plugins) { %>
            <% if (plugins.wa_bulk && plugins.wa_bulk.is_active) { %>
                <a href="/wa-bulk" class="nav-item <%= currentPage === 'wa-bulk' ? 'active' : '' %>">
                    <i class="fa-brands fa-whatsapp"></i> WhatsApp Bulk
                </a>
            <% } %>

            <% if (plugins.network_monitor && plugins.network_monitor.is_active) { %>
                <a href="/network-monitor" class="nav-item <%= currentPage === 'network-monitor' ? 'active' : '' %>">
                    <i class="fa-solid fa-chart-line"></i> Network Monitor
                </a>
            <% } %>
        <% } %>

        <div class="nav-section"><%= t.system %></div>
        <a href="/settings" class="nav-item <%= currentPage === 'settings' ? 'active' : '' %>">
            <i class="fa-solid fa-gears"></i> <%= t.settings %>
        </a>
        <a href="/logout" class="nav-item text-danger">
            <i class="fa-solid fa-right-from-bracket"></i> <%= t.logout %>
        </a>
    </div>
</div>

