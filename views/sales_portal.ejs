<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('partials/head') %>
    <style>
        :root { --primary: #3B82F6; --primary-soft: rgba(59, 130, 246, 0.1); }
        body { background: var(--bg-color); color: var(--text); margin: 0; padding-bottom: 90px; transition: background 0.3s, color 0.3s; display: flex; flex-direction: column; min-height: 100vh; }
        .portal-header { background: var(--sidebar-bg); padding: 20px; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; position: sticky; top: 0; z-index: 1000; backdrop-filter: blur(10px); width: 100%; }
        .portal-title { font-size: 20px; font-weight: 700; margin: 0; }
        .portal-subtitle { font-size: 13px; color: var(--muted); margin-top: 4px; }
        .content { padding: 20px; width: 100%; flex: 1; }
        .section-title { font-size: 14px; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: 1px; margin: 24px 0 12px; }
        
        .stats-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 20px; }
        .stat-card { background: var(--card-bg); border: 1px solid var(--border); border-radius: 16px; padding: 16px; }
        .stat-val { font-size: 26px; font-weight: 700; margin-bottom: 4px; }
        .stat-lab { font-size: 11px; color: var(--muted); font-weight: 600; text-transform: uppercase; }
        
        .lead-card { background: var(--card-bg); border: 1px solid var(--border); border-radius: 16px; padding: 16px; margin-bottom: 12px; display: flex; justify-content: space-between; align-items: center; transition: transform 0.2s; }
        .lead-card:active { transform: scale(0.98); background: rgba(255,255,255,0.03); }
        .lead-info h4 { margin: 0; font-size: 15px; font-weight: 600; }
        .lead-info p { margin: 4px 0 0; font-size: 12px; color: var(--muted); }
        .lead-status { font-size: 10px; font-weight: 700; color: #10B981; background: rgba(16, 185, 129, 0.1); padding: 4px 8px; border-radius: 6px; text-transform: uppercase; }

        .btn-add { background: #3B82F6; color: white; border: none; padding: 14px; border-radius: 12px; width: 100%; font-size: 15px; font-weight: 600; margin-bottom: 24px; display: flex; align-items: center; justify-content: center; gap: 8px; cursor: pointer; }
        
        .bottom-nav { position: fixed; bottom: 0; left: 0; right: 0; background: var(--topbar-bg); backdrop-filter: blur(10px); border-top: 1px solid var(--border); display: flex; justify-content: space-around; padding: 12px 10px; z-index: 1000; }
        .nav-item { display: flex; flex-direction: column; align-items: center; gap: 4px; color: var(--muted); text-decoration: none; font-size: 11px; font-weight: 500; }
        .nav-item.active { color: #3B82F6; }

        .overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.8); backdrop-filter: blur(4px); display: none; align-items: center; justify-content: center; z-index: 2000; padding: 20px; }
        .modal { background: var(--sidebar-bg); border: 1px solid var(--border); border-radius: 20px; width: 100%; max-width: 500px; padding: 24px; max-height: 90vh; overflow-y: auto; }
        .modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
        .form-group { margin-bottom: 16px; }
        .form-group label { display: block; font-size: 12px; color: var(--muted); margin-bottom: 6px; }
        .form-control { background: var(--input-bg); border: 1px solid var(--border); border-radius: 10px; padding: 12px; width: 100%; color: var(--text); font-family: inherit; }
    </style>
</head>
<body>
    <div class="portal-header">
        <div>
            <h1 class="portal-title">Portal Sales</h1>
            <p class="portal-subtitle">Target tercapai, komisi menanti!</p>
        </div>
        <button id="themeToggle" style="background:var(--card-bg); border:1px solid var(--border); color:var(--text); width:38px; height:38px; border-radius:10px; cursor:pointer; display:flex; align-items:center; justify-content:center;">
            <i class="fas fa-moon"></i>
        </button>
    </div>

    <div class="content">
        <div class="stats-row">
            <div class="stat-card">
                <div class="stat-val"><%= totalLeads %></div>
                <div class="stat-lab">Total Leads</div>
            </div>
            <div class="stat-card">
                <div class="stat-val"><%= closingMonth %></div>
                <div class="stat-lab">Closing Bln Ini</div>
            </div>
        </div>
        
        <div class="stat-card" style="margin-bottom: 24px; border-color: rgba(16, 185, 129, 0.2); background: rgba(16, 185, 129, 0.05);">
            <div class="stat-lab" style="color: #10B981;">Estimasi Komisi</div>
            <div class="stat-val" style="color: #10B981; font-size: 28px;">Rp <%= parseFloat(commission).toLocaleString('id-ID') %></div>
        </div>

        <button class="btn-add" onclick="document.getElementById('modalAdd').style.display='flex'">
            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M12 4v16m8-8H4"/></svg>
            Tambah Lead Baru
        </button>

        <div class="section-title">Leads Terbaru</div>
        <% if (leads.length > 0) { %>
            <% leads.forEach(l => { %>
                <div class="lead-card">
                    <div class="lead-info">
                        <h4><%= l.name %></h4>
                        <p><%= l.address || 'Tanpa alamat' %></p>
                        <p style="font-size: 10px; opacity: 0.6;"><%= new Date(l.created_at).toLocaleDateString('id-ID') %></p>
                    </div>
                    <span class="lead-status">AKTIF</span>
                </div>
            <% }); %>
        <% } else { %>
            <div style="text-align: center; padding: 40px; color: #94A3B8;">Belum ada data leads.</div>
        <% } %>
    </div>

    <!-- Modal Add Lead -->
    <div id="modalAdd" class="overlay">
        <div class="modal">
            <div class="modal-header">
                <h3 style="margin:0">Input Lead Baru</h3>
                <button onclick="document.getElementById('modalAdd').style.display='none'" style="background:none; border:none; color:#94A3B8; font-size:24px; cursor:pointer;">&times;</button>
            </div>
            <form id="leadForm">
                <div class="form-group">
                    <label>Nama Pelanggan *</label>
                    <input type="text" id="fName" class="form-control" required placeholder="Contoh: Budi Santoso">
                </div>
                <div class="form-group">
                    <label>No. WhatsApp *</label>
                    <input type="text" id="fPhone" class="form-control" required placeholder="08xxxxxxxx">
                </div>
                <div class="form-group">
                    <label>Email (Opsional)</label>
                    <input type="email" id="fEmail" class="form-control" placeholder="pelanggan@mail.com">
                </div>
                <div class="form-group">
                    <label>Alamat Lengkap</label>
                    <textarea id="fAddress" class="form-control" rows="3" placeholder="Jl. Raya No. 123..."></textarea>
                </div>
                <div class="form-group">
                    <label>Username PPPoE (Opsional)</label>
                    <div style="display:flex; gap:8px;">
                        <input type="text" id="fPppoe" class="form-control" placeholder="Ambil dari MikroTik..." style="flex:1">
                        <button type="button" class="btn" onclick="fetchActivePppoe()" title="Ambil dari MikroTik Aktif" style="background:var(--primary-soft); color:var(--primary); width:42px; height:42px; display:flex; align-items:center; justify-content:center; border:1px solid var(--border); border-radius:10px; padding:0;">
                            <i class="fas fa-search-location"></i>
                        </button>
                    </div>
                </div>
                <input type="hidden" id="fRouterId" value="">
                <div class="form-group">
                    <label>Paket Internet</label>
                    <select id="fPackage" class="form-control">
                        <% packages.forEach(p => { %>
                            <option value="<%= p.id %>"><%= p.name %> (Rp <%= parseFloat(p.price).toLocaleString('id-ID') %>)</option>
                        <% }); %>
                    </select>
                </div>
                <button type="submit" class="btn-add" style="margin-bottom:0; margin-top:20px;">Kirim Data Lead</button>
            </form>
        </div>
    </div>

    <div class="bottom-nav">
        <a href="/sales" class="nav-item active">
            <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
            <span>Sales</span>
        </a>
        <a href="/logout" class="nav-item">
            <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
            <span>Keluar</span>
        </a>
    </div>

    <!-- Modal Pick PPPoE -->
    <div id="pppoeModal" class="overlay" style="z-index:3000;">
        <div class="modal" style="max-width:450px;">
            <div class="modal-header">
                <h3 class="modal-title" style="margin:0">Pilih PPPoE Aktif</h3>
                <button class="close-btn" onclick="document.getElementById('pppoeModal').style.display='none'" style="background:none; border:none; color:var(--muted); font-size:24px; cursor:pointer;">&times;</button>
            </div>
            <div style="margin-bottom:15px;">
                <input type="text" id="pppoeSearch" class="form-control" placeholder="Cari username..." onkeyup="filterPppoeList()">
            </div>
            <div id="pppoeList" style="max-height:350px; overflow-y:auto; border:1px solid var(--border); border-radius:12px; background:var(--input-bg);">
                <div style="padding:30px; text-align:center; color:var(--muted);">Sedang memuat data...</div>
            </div>
        </div>
    </div>

    <div id="toast" style="position:fixed;bottom:80px;left:20px;right:20px;background:var(--toast-bg);color:var(--text);border:1px solid var(--border);border-radius:12px;padding:14px 20px;z-index:9999;display:none;font-size:14px;box-shadow:0 10px 25px rgba(0,0,0,0.2);"></div>

    <script>
        document.getElementById('leadForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const body = {
                name: document.getElementById('fName').value,
                phone: document.getElementById('fPhone').value,
                email: document.getElementById('fEmail').value,
                address: document.getElementById('fAddress').value,
                package_id: document.getElementById('fPackage').value,
                pppoe_username: document.getElementById('fPppoe').value,
                router_id: document.getElementById('fRouterId').value,
                status: 'active'
            };
            try {
                const res = await fetch('/customers', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify(body)
                });
                const d = await res.json();
                showToast(d.message, d.success ? 'success' : 'error');
                if (d.success) {
                    document.getElementById('modalAdd').style.display = 'none';
                    setTimeout(() => location.reload(), 1000);
                }
            } catch(e) {
                showToast('Gagal: ' + e.message, 'error');
            }
        });
        function showToast(msg,type){const t=document.getElementById('toast');t.textContent=msg;t.style.color=type==='success'?'#10B981':'#EF4444';t.style.display='block';setTimeout(()=>t.style.display='none',3500);}

        let pppoeData = [];
        async function fetchActivePppoe() {
            const modal = document.getElementById('pppoeModal');
            const list = document.getElementById('pppoeList');
            modal.style.display = 'flex';
            list.innerHTML = '<div style="padding:40px; text-align:center;"><i class="fas fa-spinner fa-spin"></i><br><br>Menghubungi MikroTik...</div>';
            try {
                const res = await fetch('/api/mikrotik/active-pppoe-unlinked');
                const d = await res.json();
                if (d.success) {
                    pppoeData = d.data;
                    renderPppoeList(pppoeData);
                } else {
                    list.innerHTML = `<div style="padding:30px; text-align:center; color:#EF4444">${d.message}</div>`;
                }
            } catch (e) {
                list.innerHTML = `<div style="padding:30px; text-align:center; color:#EF4444">Gagal memuat data</div>`;
            }
        }

        function renderPppoeList(data) {
            const list = document.getElementById('pppoeList');
            if (data.length === 0) {
                list.innerHTML = '<div style="padding:40px; text-align:center; color:var(--muted)">Tidak ada session aktif baru.</div>';
                return;
            }
            list.innerHTML = data.map(item => `
                <div onclick="selectPppoe('${item.username}', '${item.router_id}')" style="padding:14px 18px; border-bottom:1px solid var(--border); cursor:pointer;">
                    <div style="font-weight:600; color:var(--primary); font-size:14px;">${item.username}</div>
                    <div style="display:flex; justify-content:space-between; margin-top:4px; font-size:11px; color:var(--muted);">
                        <span>${item.router_name}</span>
                        <span>${item.uptime}</span>
                    </div>
                </div>
            `).join('');
        }

        function filterPppoeList() {
            const query = document.getElementById('pppoeSearch').value.toLowerCase();
            const filtered = pppoeData.filter(item => item.username.toLowerCase().includes(query));
            renderPppoeList(filtered);
        }

        function selectPppoe(user, routerId) {
            document.getElementById('fPppoe').value = user;
            document.getElementById('fRouterId').value = routerId;
            document.getElementById('pppoeModal').style.display = 'none';
            showToast('PPPoE terpilih: ' + user, 'success');
        }

        // Theme Logic
        const themeToggle = document.getElementById('themeToggle');
        const themeIcon = themeToggle.querySelector('i');
        function updateThemeUI() {
            const isLight = document.documentElement.classList.contains('light-theme');
            themeIcon.className = isLight ? 'fas fa-sun' : 'fas fa-moon';
            themeToggle.style.color = isLight ? '#F59E0B' : 'var(--text)';
        }
        updateThemeUI();
        themeToggle.addEventListener('click', () => {
            const isLight = document.documentElement.classList.toggle('light-theme');
            localStorage.setItem('theme', isLight ? 'light' : 'dark');
            updateThemeUI();
        });
    </script>
</body>
</html>
